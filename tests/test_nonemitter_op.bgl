/* test_nonemitter_op.bgl — non-emitter operator on a class */
#beguilerSettings {
    target = z5;
    informName = "none";
    outputPath = "tests/output";
}

class Counter : object {
    int value = 0;

    replace bool operator == (Counter other){
        return self.value == other.value;
    }

    int operator + (int n){
        return self.value + n;
    }
}

Counter ctrA { value = 5; }
Counter ctrB { value = 5; }

// Conversion operators (spec §5.6.4) — operator() with zero params declares that this type
// is implicitly convertible to the return type. Wrapping a raw int in a typed class gives
// type-safety without runtime cost.
class Temperature : object {
    int celsius = 0;
    // Implicit conversion: Temperature flows into any int context automatically.
    emitter int operator() { $self.celsius }
}

// An explicit conversion operator only fires at explicit `(Type)expr` cast sites, not via
// implicit coercion. Used when a conversion is legal but not intended to happen silently.
class Distance : object {
    int meters = 0;
    explicit emitter int operator() { $self.meters }
}

Temperature t { celsius = 20; }
Distance    d { meters = 100; }

void main(){
    if(ctrA == ctrB) print("equal");
    int sum = ctrA + 10;

    // Implicit conversion — t flows into int context without any cast
    int c = t;
    int doubled = t + t;

    // Explicit conversion — requires the cast
    int m = (int)d;
}
