!% -G
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
[__glkHook _vararg_count api args retval;
    @copy sp api;
    args=_vararg_count - 1;
    @glk api args retval;
    return retval;
];
object _glulx
;
object _bglUtil
;
object bgl
  with glulx _glulx,
       utilities _bglutil
;
[doubled n;
    return n * 2;
];
[tripled n;
    return n * 3;
];
! test_inf_mode_bgl_autodetect.inf — plain #bgl auto-detects between declaration
! mode and statement mode by inspecting the first token(s).
!
! Per the rule "no local variable declarations in statement islands", any
! `Type ident` shape (function form `Type ident(`, variable form `Type ident;`
! or `Type ident = ...`) elevates to declaration mode — there is no typed-local
! form in stmt-mode #bgl{} blocks.
!
! Cases exercised:
!   - #bgl{ typed function }         → declaration mode; registers global routine
!   - #bgl{ typed variable = ... }   → declaration mode; elevates to global
!   - #bgl{ assignment / call }      → statement mode
!   - #bgl single-line               → always statement mode
!
! Mixed-content blocks (decl-shaped first line followed by bare statements) are
! covered by the negative test _test_inf_mode_bgl_mixed_content.inf.

! Auto-detected as declaration mode (typed function): doubled() registers globally
! and is callable from raw I6 below.



! Auto-detected as declaration mode (typed function): tripled() registers globally too.



! Auto-detected as declaration mode (typed variable): elevates to a global int.

global counter = 0;


[ Main x;
    x = 5;
    print "before bgl.^";

    ! Auto-detected as statement mode (assignment): runs as loose statements.
    x = doubled(x);
counter=counter + 1;


    ! Single-line #bgl is always statement-mode.
    x = tripled(x);


    print "x = ", x, "^";
];

