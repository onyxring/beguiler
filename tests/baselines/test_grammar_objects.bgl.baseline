!% -G
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
constant story = "";
constant headline = "";
object whiff
  with perform [;
    print (string)"You take a whiff.";
  ]
;
[whiffsub;
                whiff.perform();
            ];
verb 'whiff'
    * -> whiff;
object nudge
  with perform [;
    print (string)"You nudge it.";
  ]
;
[nudgesub;
                nudge.perform();
            ];
verb 'nudge'
    * noun -> nudge;
verb 'hang'
    * held 'on' noun -> puton;
verb 'place'
    * held 'on' noun -> puton;
verb 'grab'
    * noun -> Take;
verb 'toss'
    * held -> Drop;
verb 'snatch'
    * noun -> Take;
verb 'inspect'
    * noun -> Examine;
verb 'nab'
    * noun -> Take;
extend 'discard'
    * held -> Drop;
verb 'study'
    * noun -> Examine;
