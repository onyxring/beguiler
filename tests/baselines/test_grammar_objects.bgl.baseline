!% -G
!% -E1

    Constant story    = "";
    Constant headline = "";

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object whiff
  with perform [;
    print (string)"You take a whiff.";
  ]
;
[whiffsub;
                whiff.perform();
            ];
verb 'whiff'
    * -> whiff;
object nudge
  with perform [;
    print (string)"You nudge it.";
  ]
;
[nudgesub;
                nudge.perform();
            ];
verb 'nudge'
    * noun -> nudge;
verb 'hang'
    * held 'on' noun -> puton;
verb 'place'
    * held 'on' noun -> puton;
verb 'grab'
    * noun -> Take;
verb 'toss'
    * held -> Drop;
verb 'snatch'
    * noun -> Take;
verb 'inspect'
    * noun -> Examine;
verb 'nab'
    * noun -> Take;
extend 'discard'
    * held -> Drop;
verb 'study'
    * noun -> Examine;
