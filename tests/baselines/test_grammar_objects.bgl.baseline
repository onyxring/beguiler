!% -G
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object whiff
  with handler [;
    print (string)"You take a whiff.";
  ]
;
[whiffsub;
                whiff.handler();
            ];
verb 'whiff'
    * -> whiff;
object nudge
  with handler [;
    print (string)"You nudge it.";
  ]
;
[nudgesub;
                nudge.handler();
            ];
verb 'nudge'
    * noun -> nudge;
verb 'hang'
    * held 'on' noun -> puton;
verb 'place'
    * held 'on' noun -> puton;
verb 'grab'
    * noun -> Take;
verb 'toss'
    * held -> Drop;
verb 'snatch'
    * noun -> Take;
verb 'inspect'
    * noun -> Examine;
verb 'nab'
    * noun -> Take;
extend 'discard'
    * held -> Drop;
verb 'study'
    * noun -> Examine;

    [main; 
        bglInit();
        _oldmain();
    ];

