!% -v5
!% -E1
Constant beguiler       = 1000;
Constant beguilerMajor  = 1;
Constant beguilerMinor  = 0;
Constant beguilerPatch  = 0;
[bglInit;
];

Array _bglWorldBuf --> 257;   ! capacity word (-->0) + 256 object slots

object bglWorld
    with getAll [ o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o) {
            if (i > 256) break;
            _bglWorldBuf-->i = o;
            i++;
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    getFiltered [ pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o) {
            if (i > 256) break;
            if (indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    inParent [ parent pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o in parent) {
            if (i > 256) break;
            if (pred == 0 || indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    ofClass [ cls pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o ofclass cls) {
            if (i > 256) break;
            if (pred == 0 || indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ]
;

global _bgl_animal_count = 0;
class animal
  class object
  with
    short_name,
    description,
    maxage 20,
    speak[;
    ]
;
class dog
  class animal
  with
    speak[;
    ]
;
object myhelper
  with getvalue [;
    return self.value;
  ],
       value 0
;
place testroom
  with short_name "Test Room",
       description "A room for testing."
  has light
;
attribute light;
[main v;
    _bgl_animal_count=_bgl_animal_count + 1;
    myhelper.getvalue()=myhelper.getvalue();
    print v;
];
