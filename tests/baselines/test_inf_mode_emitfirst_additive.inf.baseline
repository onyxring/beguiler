!% -G
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];


        Constant FROM_FIRST_ISLAND;
    

        Constant FROM_SECOND_ISLAND;
    

        Constant FROM_THIRD_ISLAND;
    
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
[__glkHook _vararg_count api args retval;
    @copy sp api;
    args=_vararg_count - 1;
    @glk api args retval;
    return retval;
];
object _glulx
;
object _bglUtil
;
object bgl
  with glulx _glulx,
       utilities _bglutil
;
! test_inf_mode_emitfirst_additive.inf — Slice 5c: #emitfirst is additive across all
! references in the same source file. Multiple #bglDecl islands each contributing an
! #emitfirst block must all register; the previous per-file dedup gate is gone (#once
! is now the sole mechanism for re-include cycle protection).










[ Main;
    print "hi.^";
];


end;
