!% -v5
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;

! test_inf_mode_verb_in_island.inf — verb declarations inside `#bgl{}` islands
! must emit the corresponding `object <verbname>`, `[<verbname>sub;…]` action
! routine, and `verb '<word>'` grammar block. Two regressions blocked this:
!   (1) The `#bgl{}` auto-detector only recognised `Type Name (`/`;`/`=` as a
!       declaration form, not `Type Name {`, so `verb foo {…}` got routed to
!       the statement parser and silently dropped.
!   (2) `registerVerbObject` didn't re-push to globals when claiming a pre-pass
!       stub, so even when parsing succeeded the verb never reached emit.


constant story = "";
constant headline = "";
object helloverb
  with perform [;
    print (string)"hello";
  ]
;
[helloverbsub;
                helloverb.perform();
            ];
verb 'greet'
    * noun -> helloverb;


end;
