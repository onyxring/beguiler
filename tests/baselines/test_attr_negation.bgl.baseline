!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
class room
  class object
  has light
;
room cellar
  has
;
room darkVault
  has ~light
;
room lampShelf
  has light ~scenery container
;
room courtyard
;
[main;
    if (~~(cellar has light)) {
        print (string)"cellar dark^";
    }
    if (~~(darkvault has light)) {
        print (string)"darkVault dark^";
    }
    if ((lampshelf has light) && ~~(lampshelf has scenery)&&(lampshelf has container)) {
        print (string)"lampShelf composed correctly^";
    }
    if ((courtyard has light)) {
        print (string)"courtyard inherits light^";
    }
];
