!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object widget
  with count 0,
       bump [;
    self.count=self.count + 1;
    return self.count;
  ]
;
[takesAnyObject o;
];
[main x w y;
    x=widget.bump();
    w = widget;
    y=w.bump();
    takesanyobject(widget);
];
