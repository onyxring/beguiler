!% -G
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object wibble
  with handler [;
    print (string)"wibble";
  ]
;
[wibblesub;
                wibble.handler();
            ];
verb 'wibble'
    * noun -> wibble;
[f;
    takesub();
    <take>;
    <take ball>;
    <take ball key>;
    <glonk ball>;
    <wibble ball>;
    <take ball>;
    rtrue;
];

    [main; 
        bglInit();
        _oldmain();
    ];

