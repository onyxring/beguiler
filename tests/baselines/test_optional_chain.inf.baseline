!% -v5
!% -E1
global _bgl_temp;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
[main x y;
    x = nothing;
    _bgl_temp = x; if (_bgl_temp ~= nothing) { _bgl_temp = parent(_bgl_temp); }
    _bgl_temp = _bgl_temp; if (~~(_bgl_temp ~= nothing)) _bgl_temp = x;
    y = _bgl_temp;
    if (x ~= nothing) {
        print (string)"present";
    }
    if (~~(x ~= nothing)) {
        print (string)"absent";
    }
    if (x ~= nothing) {
    remove x;
    }
];
