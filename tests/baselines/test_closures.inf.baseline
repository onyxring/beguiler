!% -v5
!% -E1
[bglInit;
];
global _bglCap3;
global _bglCap2;
global _bglCap1;
global _bglCap0;

Array _bglWorldBuf --> 257;   ! capacity word (-->0) + 256 object slots

object bglWorld
    with getAll [ o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o) {
            if (i > 256) break;
            _bglWorldBuf-->i = o;
            i++;
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    getFiltered [ pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o) {
            if (i > 256) break;
            if (indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    inParent [ parent pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o in parent) {
            if (i > 256) break;
            if (pred == 0 || indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    ofClass [ cls pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o ofclass cls) {
            if (i > 256) break;
            if (pred == 0 || indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ]
;

[apply fn x result;
    result=fn(x);
];
[test1 multiplier;
    _bglCap0 = multiplier;
    apply(_bglLambda_0, 5);
];
[test2 offset;
    offset = 10;
    _bglCap1 = offset;
    apply(_bglLambda_1, 3);
];
[test3 a b;
    _bglCap2 = a;
    _bglCap3 = b;
    apply(_bglLambda_2, 2);
];
[test4;
    apply(_bglLambda_3, 5);
];
[main;
    test1(3);
    test2();
    test3(4, 5);
    test4();
];
[_bglLambda_0 x;
    return x * _bglCap0;
];
[_bglLambda_1 x;
    return x + _bglCap1;
];
[_bglLambda_2 x;
    return x * _bglCap2 + _bglCap3;
];
[_bglLambda_3 x;
    return x + 1;
];
