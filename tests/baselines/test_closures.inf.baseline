!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
global _bglCap3;
global _bglCap2;
global _bglCap1;
global _bglCap0;
object _bglutil
;
object bgl
;
[apply fn x result;
    result=fn(x);
];
[test1 multiplier;
    _bglCap0 = multiplier;
    apply(_bglLambda_0, 5);
];
[test2 offset;
    offset = 10;
    _bglCap1 = offset;
    apply(_bglLambda_1, 3);
];
[test3 a b;
    _bglCap2 = a;
    _bglCap3 = b;
    apply(_bglLambda_2, 2);
];
[test4;
    apply(_bglLambda_3, 5);
];
[main;
    test1(3);
    test2();
    test3(4, 5);
    test4();
];
[_bglLambda_0 x;
    return x * _bglCap0;
];
[_bglLambda_1 x;
    return x + _bglCap1;
];
[_bglLambda_2 x;
    return x * _bglCap2 + _bglCap3;
];
[_bglLambda_3 x;
    return x + 1;
];
