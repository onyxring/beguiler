!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglutil
;
object bgl
  with util _bglutil
;
class room
  class object
  with
    visits 0,
    visit[;
        self.visits=self.visits + 1;
    ],
    getvisits[;
        return self.visits;
    ]
;
room r1;
room r2;
array g_rooms table r1 r2;
[main v v2;
     g_rooms-->(0+1) .visit();
    v= g_rooms-->(0+1) .visits;
    v2= g_rooms-->(0+1) .getvisits();
     g_rooms-->(1+1) .visit();
];
