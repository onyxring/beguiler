!% -v5
!% -E1

    Constant story    = "";
    Constant headline = "";

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object tinker
  with perform [;
    print (string)"tinker";
  ]
;
[tinkersub;
                tinker.perform();
            ];
verb 'tinker'
    * noun -> tinker;
extend 'tinker' first
    * 'roughly' noun -> tinker;
extend 'tinker' first
    * 'carefully' noun -> tinker;
extend 'tinker' first
    * 'gingerly' noun -> tinker;
extend 'tinker'
    * 'quickly' noun -> tinker;
extend 'tinker'
    * 'slowly' noun -> tinker;
extend 'tinker'
    * 'lazily' noun -> tinker;
[main;
];
