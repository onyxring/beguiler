!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object tinker
  with handler [;
    print (string)"tinker";
  ]
;
[tinkersub;
                tinker.handler();
            ];
verb 'tinker'
    * noun -> tinker;
extend 'tinker' first
    * 'roughly' noun -> tinker;
extend 'tinker' first
    * 'carefully' noun -> tinker;
extend 'tinker' first
    * 'gingerly' noun -> tinker;
extend 'tinker'
    * 'quickly' noun -> tinker;
extend 'tinker'
    * 'slowly' noun -> tinker;
extend 'tinker'
    * 'lazily' noun -> tinker;
[main;
];

    [main; 
        bglInit();
        _oldmain();
    ];

