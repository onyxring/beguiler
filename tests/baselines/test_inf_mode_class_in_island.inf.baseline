!% -G
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglArray
  with isTracked [arr;
    return  arr-->( arr-->(-1+1) -1+1) ==36996&& arr-->( arr-->(-1+1) -2+1) >=0;
  ],
       size [arr;
    if (self.istracked(arr)) {
        return  arr-->(-1+1) -2;
    }
    return  arr-->(-1+1) ;
  ],
       length [arr;
    if (self.istracked(arr)) {
        return  arr-->( arr-->(-1+1) -2+1) ;
    }
    return  arr-->(-1+1) ;
  ],
       setLength [arr n;
    if (self.istracked(arr)) {
        if (n<0) {
            print (string)"^[Beguile runtime error: setLength value exceeds signed range (max 32767 on Z, 2^31-1 on Glulx)]^";
             quit; 
        }
        arr-->(_bglArray.size(arr)+1) = n;
    }
  ]
;
[__glkHook _vararg_count api args retval;
    @copy sp api;
    args=_vararg_count - 1;
    @glk api args retval;
    return retval;
];
object _glulx
;
object _bglUtil
;
object bgl
  with glulx _glulx,
       utilities _bglutil
;
! test_inf_mode_class_in_island.inf — Slice 4: pre-scan walks .inf body for #bgl-island
! declarations so class/enum names register as types before Pass 2 grammar matching.
!
! Without Slice 4, `class counter {}` inside #bgl{} fails with "Near 'class': expected
! type name (in class declaration)" because the grammar rule `{"class", TYPE_NAME}`
! requires the class name to already be a registered type at match time.
!
! Cases exercised:
!   - #bglDecl declares a class; raw I6 below references the class via instance.
!   - #bgl auto-detects a class declaration and routes to declaration mode.
!   - Forward reference: a class declared in a LATER island, referenced earlier in the
!     .inf body via raw I6, resolves because pre-scan walks all islands first.

! Class declared via #bglDecl. Pre-scan registers `counter` as a type so the grammar
! rule {class, TYPE_NAME} matches in Pass 2.

class counter
  with
    value 0,
    increment[;
        self.value=self.value + 1;
        return self.value;
    ]
;


! Class declared via auto-detect #bgl. Same pre-scan path.

class doubler
  with
    factor 2,
    apply[n;
        return n * self.factor;
    ]
;


! File-scope instance of counter (Beguile-side declaration, but referenced from raw I6).

counter myCounter;
doubler myDoubler;


[ Main x;
    print "before bgl.^";

    mycounter.increment();
mycounter.increment();
x = mycounter.value;
x = mydoubler.apply(x);


    print "x = ", x, "^";
];

