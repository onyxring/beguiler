!% -G
!% -E1
global _bgl_temp0;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _glulx
;
object _bglutil
;
object bgl
  with glulx _glulx,
       util _bglutil
;
[testarithmetic a b sum diff prod quot rem mixed neg;
    a = 10;
    b = 3;
    sum=a + b;
    diff=a - b;
    prod=a * b;
    quot=a / b;
    rem=a % b;
    mixed=(a + b) * (a - b);
    neg=-a;
];
[testcomparison x y eq neq lt lte gt gte;
    x = 5;
    y = 10;
    eq=x == y;
    neq=x ~= y;
    lt=x < y;
    lte=x <= y;
    gt=x > y;
    gte=x >= y;
];
[testlogical a b andresult orresult notresult complex;
    a=true;
    b=false;
    andresult=a && b;
    orresult=a || b;
    notresult=~~a;
    complex=~~b;
];
[testcompound n;
    n = 10;
    n = n + 5;
    n = n - 2;
    n = n * 3;
    n = n / 4;
    n = n % 7;
];
[testincdec i;
    i = 0;
     i++ ;
     i-- ;
     i++ ;
     i-- ;
];
[testternary x tval;
    x = 7;
    if (x>=0) _bgl_temp0 = x; else _bgl_temp0 = 0;
    tval=_bgl_temp0;
];
[testcast v n b;
    v = 42;
    n=v;
    b=n;
];
[printresult x;
    print x;
];
[testmixed a b r1 apb r2 r3;
    a = 4;
    b = 6;
    r1=a * a + b * b;
    apb=a + b;
    r2=apb * apb;
    r3=r2 - 1;
    printresult(r1);
    printresult(r3);
];
[testbitwise a b and_ or_;
    a = 12;
    b = 10;
    and_=a & b;
    or_=a | b;
    a = a & 7;
    b = b | 4;
];
[testexpressions;
    testarithmetic();
    testcomparison();
    testlogical();
    testcompound();
    testincdec();
    testternary();
    testcast();
    testmixed();
    testbitwise();
];
