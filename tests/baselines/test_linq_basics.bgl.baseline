    _bglArray.setLength(dst, writeCount);
     _bglLinqParity = 1 - _bglLinqParity; 
    return dst;
  ],
       map [src f dst cap srcLen i;
    
            if(_bglLinqParity == 0) dst = _bglLinqScratchB;
            else                    dst = _bglLinqScratchA;
            cap = _BGL_LINQ_SCRATCH_SIZE;
        
