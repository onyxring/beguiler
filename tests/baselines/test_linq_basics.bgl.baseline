    }
  ],
       filter [src pred dst cap writeCount srcLen i elem;
    
            if(_bglLinqParity == 0) dst = _bglLinqScratchB;
            else                    dst = _bglLinqScratchA;
            cap = _BGL_LINQ_SCRATCH_SIZE;
        
    writeCount = 0;
    srcLen=_bglArray.length(src);
    for (i = 0 : i < srclen : i++) {
        elem =  src-->(i+1) ;
        if (pred(elem)) {
