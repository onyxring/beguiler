!% -v5
!% -E1
Release 1;
[bglInit;
];

Array _bglWorldBuf --> 257;   ! capacity word (-->0) + 256 object slots

object bglWorld
    with getAll [ o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o) {
            if (i > 256) break;
            _bglWorldBuf-->i = o;
            i++;
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    getFiltered [ pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o) {
            if (i > 256) break;
            if (indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    inParent [ parent pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o in parent) {
            if (i > 256) break;
            if (pred == 0 || indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    ofClass [ cls pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o ofclass cls) {
            if (i > 256) break;
            if (pred == 0 || indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ]
;

[_bgl_replaced_greet_0 x;
    return x + 1;
];
[_bgl_replaced_step_0 n;
    return n;
];
[_bgl_replaced_calculate_0 n;
    return n + 1;
];
[main a b c d;
    a=greet(1);
    b=compute(3,4);
    c=step(5);
    d=calculate(5);
];
[greet x r;
    r=_bgl_replaced_greet_0(x);
    return r + 10;
];
[compute a b;
    return a * b;
];
[_bgl_replaced_step_1 n;
    return _bgl_replaced_step_0(n) + 100;
];
[step n;
    return _bgl_replaced_step_1(n) + 200;
];
[calculate n;
    return _bgl_replaced_calculate_0(n) * 2;
];
