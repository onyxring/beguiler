!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
property hidden_flag;
object bar
  with isNorthBound [;
    return selected_direction == n_to;
  ],
       isHiddenCheck [;
    return selected_direction == hidden_flag;
  ]
;
[main;
    if (bar.isnorthbound()) {
        print (string)"north^";
    }
    if (bar.ishiddencheck()) {
        print (string)"hidden^";
    }
];
