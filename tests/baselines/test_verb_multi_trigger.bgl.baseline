!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object typenum
  with handler [;
    print (string)"type num";
  ]
;
[typenumsub;
                typenum.handler();
            ];
verb 'typo' 'entrz' 'putz'
    * number 'into'/'in'/'on'/'onto' noun -> typenum;
object toggle
  with handler [;
    print (string)"toggle";
  ]
;
[togglesub;
                toggle.handler();
            ];
verb 'flip' 'flop'
    * noun -> toggle
    * noun 'twice' -> toggle;
object beep
  with handler [;
    print (string)"beep";
  ]
;
[beepsub;
                beep.handler();
            ];
verb 'beep'
    * noun -> beep;
object chirp
  with handler [;
    print (string)"chirp";
  ]
;
[chirpsub;
                chirp.handler();
            ];
verb 'chirp'
    * noun -> chirp;
extend 'beep'
    * noun -> chirp;
verb 'tweet'
    * noun -> chirp;
object squelch
  with handler [;
    print (string)"squelch";
  ]
;
[squelchsub;
                squelch.handler();
            ];
verb 'squelch'
    * noun -> squelch;
verb 'mash' 'squish'
    * noun -> squelch;
extend 'squelch'
    * noun 'firmly' -> squelch;
verb 'crush'
    * noun 'firmly' -> squelch;
verb 'grind'
    * noun 'firmly' -> squelch;
[main;
];

    [main; 
        bglInit();
        _oldmain();
    ];

