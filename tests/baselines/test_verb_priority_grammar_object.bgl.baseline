!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object trundle
  with handler [;
    print (string)"trundle";
  ]
;
[trundlesub;
                trundle.handler();
            ];
verb 'trundle'
    * noun -> trundle;
object smelt
  with handler [;
    print (string)"smelt";
  ]
;
[smeltsub;
                smelt.handler();
            ];
verb 'smelt'
    * noun -> smelt;
[main;
];
extend 'smelt' first
    * 'urgently' noun -> Smelt;
extend 'smelt'
    * 'quickly' noun -> Smelt;
extend 'smelt'
    * 'lazily' noun -> Smelt;
extend 'trundle' first
    * 'softly' noun -> Trundle;
extend 'trundle'
    * 'heavily' noun -> Trundle;
extend 'smelt' first
    * 'gingerly' noun -> Smelt;
extend 'trundle'
    * 'briskly' noun -> Trundle;

    [main; 
        bglInit();
        _oldmain();
    ];

