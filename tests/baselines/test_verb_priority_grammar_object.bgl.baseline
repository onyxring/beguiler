!% -v5
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
constant story = "";
constant headline = "";
object trundle
  with perform [;
    print (string)"trundle";
  ]
;
[trundlesub;
                trundle.perform();
            ];
verb 'trundle'
    * noun -> trundle;
object smelt
  with perform [;
    print (string)"smelt";
  ]
;
[smeltsub;
                smelt.perform();
            ];
verb 'smelt'
    * noun -> smelt;
[main;
];
extend 'smelt' first
    * 'urgently' noun -> Smelt;
extend 'smelt'
    * 'quickly' noun -> Smelt;
extend 'smelt'
    * 'lazily' noun -> Smelt;
extend 'trundle' first
    * 'softly' noun -> Trundle;
extend 'trundle'
    * 'heavily' noun -> Trundle;
extend 'smelt' first
    * 'gingerly' noun -> Smelt;
extend 'trundle'
    * 'briskly' noun -> Trundle;
