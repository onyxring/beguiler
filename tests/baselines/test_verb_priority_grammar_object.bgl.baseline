!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
constant story = "";
constant headline = "";
object trundle
  with perform [;
    print (string)"trundle";
  ]
;
[trundlesub;
                trundle.perform();
            ];
verb 'trundle'
    * noun -> trundle;
object smelt
  with perform [;
    print (string)"smelt";
  ]
;
[smeltsub;
                smelt.perform();
            ];
verb 'smelt'
    * noun -> smelt;
[main;
];
extend 'smelt' first
    * 'urgently' noun -> Smelt;
extend 'smelt'
    * 'quickly' noun -> Smelt;
extend 'smelt'
    * 'lazily' noun -> Smelt;
extend 'trundle' first
    * 'softly' noun -> Trundle;
extend 'trundle'
    * 'heavily' noun -> Trundle;
extend 'smelt' first
    * 'gingerly' noun -> Smelt;
extend 'trundle'
    * 'briskly' noun -> Trundle;
