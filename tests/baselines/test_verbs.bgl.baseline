!% -G
!% -E1

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object whiff
  with perform [;
    print (string)"You take a whiff of the air.";
  ]
;
[whiffsub;
                whiff.perform();
            ];
verb 'whiff'
    * -> whiff;
verb 'waft'
    * noun -> whiff;
object nudge
  with perform [;
    print (string)"You nudge it.";
  ]
;
[nudgesub;
                nudge.perform();
            ];
verb 'nudge'
    * noun -> nudge;
verb 'jostle'
    * noun -> nudge;
[handleAction a;
    if (a == ##whiff) {
        print (string)"whiffing";
    }
    else {
        if (a == ##nudge) {
            print (string)"nudging";
        }
        else {
            if (a == ##examine) {
                print (string)"examining";
            }
            else {
                print (string)"other";
            }
        }
    }
];
[testVerbs;
    handleaction(##whiff);
    handleaction(##examine);
];
object possess
  with perform [;
    print (string)"Possessed.";
  ]
;
[possesssub;
                possess.perform();
            ];
verb 'carol^s'
    * noun -> possess
    * noun -> possess;
object greet
  with perform [;
    print (string)"Greeted.";
  ]
;
[greetsub;
                greet.perform();
            ];
verb 'mr'
    * noun -> greet;
object stow
  with perform [;
    print (string)"Stowed.";
  ]
;
[stowsub;
                stow.perform();
            ];
verb 'stow'
    * held 'on'/'onto'/'upon' noun -> stow
    * held 'in'/'into'/'inside' noun -> stow;
object testObj
  with score 0,
       bump [;
    self.score=self.score + 1;
  ]
;
[testMemberAccess s;
    testobj.bump();
    s=testobj.score;
];

    [main; 
        bglInit();
        _oldmain();
    ];

