!% -G
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
constant story = "";
constant headline = "";
object whiff
  with perform [;
    print (string)"You take a whiff of the air.";
  ]
;
[whiffsub;
                whiff.perform();
            ];
verb 'whiff'
    * -> whiff;
verb 'waft'
    * noun -> whiff;
object nudge
  with perform [;
    print (string)"You nudge it.";
  ]
;
[nudgesub;
                nudge.perform();
            ];
verb 'nudge'
    * noun -> nudge;
verb 'jostle'
    * noun -> nudge;
[handleAction a;
    if (a == ##whiff) {
        print (string)"whiffing";
    }
    else {
        if (a == ##nudge) {
            print (string)"nudging";
        }
        else {
            if (a == ##examine) {
                print (string)"examining";
            }
            else {
                print (string)"other";
            }
        }
    }
];
[testVerbs;
    handleaction(##whiff);
    handleaction(##examine);
];
object possess
  with perform [;
    print (string)"Possessed.";
  ]
;
[possesssub;
                possess.perform();
            ];
verb 'carol^s'
    * noun -> possess
    * noun -> possess;
object greet
  with perform [;
    print (string)"Greeted.";
  ]
;
[greetsub;
                greet.perform();
            ];
verb 'mr'
    * noun -> greet;
object stow
  with perform [;
    print (string)"Stowed.";
  ]
;
[stowsub;
                stow.perform();
            ];
verb 'stow'
    * held 'on'/'onto'/'upon' noun -> stow
    * held 'in'/'into'/'inside' noun -> stow;
object testObj
  with bump [;
    self.score=self.score + 1;
  ],
       score 0
;
[testMemberAccess s;
    testobj.bump();
    s=testobj.score;
];
