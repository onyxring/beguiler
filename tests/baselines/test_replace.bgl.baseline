!% -v5
!% -E1
Release 1;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[greet x;
    return x + 1;
];
[step n;
    return n;
];
[calculate n;
    return n + 1;
];
[main a b c d;
    a=greet(1);
    b=compute(3,4);
    c=step(5);
    d=calculate(5);
];
[greet x r;
    r=_bgl_replaced_greet_0(x);
    return r + 10;
];
[compute a b;
    return a * b;
];
[step n;
    return _bgl_replaced_step_0(n) + 100;
];
[step n;
    return _bgl_replaced_step_1(n) + 200;
];
[calculate n;
    return _bgl_replaced_calculate_0(n) * 2;
];
