!% -v5
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object actor
  with short_name "the troll"
;
[blockMove;
    print (string)"Blundering around in the dark isn't a good idea!";
    rtrue;
];
[seeNothing;
    print (string)"nothing happens";
    rfalse;
];
[greet;
    print "hello, ";
    print (string)actor.short_name;
    rtrue;
];
[oldStyle;
    print (string)"legacy";
    rtrue;
];
[oldStyleFalse;
    rfalse;
];
[main;
    if (blockmove()) {
        print (string)" -> blockMove rtrue^";
    }
    if (~~seenothing()) {
        print (string)" -> seeNothing rfalse^";
    }
    if (greet()) {
        print (string)" -> greet rtrue^";
    }
    if (oldstyle()) {
        print (string)" -> oldStyle rtrue^";
    }
    if (~~oldstylefalse()) {
        print (string)" -> oldStyleFalse rfalse^";
    }
];
