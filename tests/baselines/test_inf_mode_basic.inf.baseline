!% -G
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglArray
  with isTracked [arr;
    return  arr-->( arr-->(-1+1) -1+1) ==36996&& arr-->( arr-->(-1+1) -2+1) >=0;
  ],
       size [arr;
    if (self.istracked(arr)) {
        return  arr-->(-1+1) -2;
    }
    return  arr-->(-1+1) ;
  ],
       length [arr;
    if (self.istracked(arr)) {
        return  arr-->( arr-->(-1+1) -2+1) ;
    }
    return  arr-->(-1+1) ;
  ],
       setLength [arr n;
    if (self.istracked(arr)) {
        if (n<0) {
            print (string)"^[Beguile runtime error: setLength value exceeds signed range (max 32767 on Z, 2^31-1 on Glulx)]^";
             quit; 
        }
        arr-->(_bglArray.size(arr)+1) = n;
    }
  ]
;
[__glkHook _vararg_count api args retval;
    @copy sp api;
    args=_vararg_count - 1;
    @glk api args retval;
    return retval;
];
object _glulx
;
object _bglUtil
;
object bgl
  with glulx _glulx,
       utilities _bglutil
;
! test_inf_mode_basic.inf — .inf-as-input mode positive baseline.
!
! Exercises the full .inf-mode pipeline:
!   1. The whole file is read as raw I6 (this comment passes through verbatim).
!   2. The Beguile Language Runtime auto-loads at the top of the output, so types
!      and emitters are available inside #bgl{} blocks.
!   3. Multi-line #bgl{...} blocks compile as Beguile statements (loose mode), then
!      splice back into the I6 stream where they appeared in source.
!   4. Single-line `#bgl stmt;` form (terminated by newline) also works.
!   5. Beguile-side identifier resolution finds Runtime symbols (bglInit, etc.)
!      and Beguile enum values (Glulx of eTarget) from inside the #bgl block.
!   6. EOF terminates the implicit raw-I6 region naturally — no missing-brace error.
!
! Per the rule "no local variable declarations in statement islands", any `Type ident`
! shape elevates to decl mode. This test stays in pure statement mode by referencing
! the enum value directly (Glulx) instead of declaring a typed local.

[ Main x;
    print "hello from raw I6.^";

    ! Multi-line #bgl block — pure statement mode: assigns a Beguile enum value
    ! to an I6 local and calls a Runtime function.
    x = glulx;
bglinit();


    ! Single-line form — this writes one statement that emits inline.
    x = x+1;


    print "x = ", x, "^";
    print "back in raw I6.^";
];

