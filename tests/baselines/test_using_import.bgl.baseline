!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object engine
  with counter 0,
       increment [;
    self.counter=self.counter + 1;
    return self.counter;
  ]
;
object app
  with eng engine
;
[main n;
    n=app.eng.increment();
];
