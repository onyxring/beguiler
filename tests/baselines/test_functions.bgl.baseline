!% -v5
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglArray
  with isTracked [arr;
    return  arr-->( arr-->(-1+1) -1+1) ==36996&& arr-->( arr-->(-1+1) -2+1) >=0;
  ],
       size [arr;
    if (self.istracked(arr)) {
        return  arr-->(-1+1) -2;
    }
    return  arr-->(-1+1) ;
  ],
       length [arr;
    if (self.istracked(arr)) {
        return  arr-->( arr-->(-1+1) -2+1) ;
    }
    return  arr-->(-1+1) ;
  ],
       setLength [arr n;
    if (self.istracked(arr)) {
        if (n<0) {
            print (string)"^[Beguile runtime error: setLength value exceeds signed range (max 32767 on Z, 2^31-1 on Glulx)]^";
             quit; 
        }
        arr-->(_bglArray.size(arr)+1) = n;
    }
  ]
;
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[sayHello;
    print (string)"hello";
];
[sayCount n;
    print n;
];
[add a b r;
    r=a + b;
    return r;
];
[isPositive n;
    if (n>0) {
        return true;
    }
    return false;
];
[clamp value lo hi;
    if (value < lo) {
        return lo;
    }
    if (value > hi) {
        return hi;
    }
    return value;
];
[doubleAdd a b c r;
    r=add(add(a,b),c);
    return r;
];
[sumTo n total i;
    total = 0;
    i = 1;
    while (i <= n) {
        total = total + i;
        i = i + 1;
    }
    return total;
];
[printAny v;
    print v;
];
[printFlag flag;
    if (flag) {
        print (string)"y";
    }
    else {
        print (string)"n";
    }
];
[main result clamped sum pos total;
    sayhello();
    saycount(3);
    result=add(4,5);
    clamped=clamp(15,0,10);
    sum=doubleadd(1,2,3);
    pos=ispositive(result);
    total=sumto(5);
    printany(result);
    printflag(pos);
];
