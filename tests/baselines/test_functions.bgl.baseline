!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with util _bglutil
;
[sayHello;
    print (string)"hello";
];
[sayCount n;
    print n;
];
[add a b r;
    r=a + b;
    return r;
];
[isPositive n;
    if (n>0) {
        return true;
    }
    return false;
];
[clamp value lo hi;
    if (value < lo) {
        return lo;
    }
    if (value > hi) {
        return hi;
    }
    return value;
];
[doubleAdd a b c r;
    r=add(add(a,b),c);
    return r;
];
[sumTo n total i;
    total = 0;
    i = 1;
    while (i <= n) {
        total = total + i;
        i = i + 1;
    }
    return total;
];
[printAny v;
    if(v == true) print "true"; else print "false";
];
[printFlag flag;
    if (flag) {
        print (string)"y";
    }
    else {
        print (string)"n";
    }
];
[main result clamped sum pos total;
    sayhello();
    saycount(3);
    result=add(4,5);
    clamped=clamp(15,0,10);
    sum=doubleadd(1,2,3);
    pos=ispositive(result);
    total=sumto(5);
    printany(result);
    printflag(pos);
];
