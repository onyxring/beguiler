!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object tickle
  with handler [;
    print (string)"tickle";
  ]
;
[ticklesub;
                tickle.handler();
            ];
verb 'tickle'
    * noun -> tickle;
extend 'tickle' first
    * 'gently' noun -> tickle;
extend 'tickle'
    * 'roughly' noun -> tickle;
object burnish
  with handler [;
    print (string)"burnish";
  ]
;
[burnishsub;
                burnish.handler();
            ];
verb 'burnish'
    * -> burnish;
extend 'burnish' first
    * 'carefully' -> burnish;
extend 'burnish'
    * 'casually' -> burnish;
[main;
];

    [main; 
        bglInit();
        _oldmain();
    ];

