!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
constant story = "";
constant headline = "";
object census
  with perform [;
    print (string)"census";
  ]
;
[censussub;
                census.perform();
            ];
verb meta 'census'
    * -> census;
verb meta 'tally'
    * -> census;
object ponder
  with perform [;
    print (string)"ponder";
  ]
;
[pondersub;
                ponder.perform();
            ];
verb 'ponder'
    * noun -> ponder;
[main;
];
