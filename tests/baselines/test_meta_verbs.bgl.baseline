!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object census
  with handler [;
    print (string)"census";
  ]
;
[censussub;
                census.handler();
            ];
verb meta 'census'
    * -> census;
verb meta 'tally'
    * -> census;
object ponder
  with handler [;
    print (string)"ponder";
  ]
;
[pondersub;
                ponder.handler();
            ];
verb 'ponder'
    * noun -> ponder;
[main;
];

    [main; 
        bglInit();
        _oldmain();
    ];

