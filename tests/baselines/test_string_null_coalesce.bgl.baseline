!% -v5
!% -E1
global _bgl_temp0;
global _bgl_temp1;
global _bgl_temp2;
global _bgl_temp3;

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[main a b c maybeName label first;
    a="hello";
    b="world";
    _bgl_temp0 = a; if (~~(_bgl_temp0 ~= 0)) _bgl_temp0 = b;
    c = _bgl_temp0;
    maybeName="";
    _bgl_temp1 = maybename; if (~~(_bgl_temp1 ~= 0)) _bgl_temp1 = "unnamed";
    label=_bgl_temp1;
    _bgl_temp3 = label; if (~~(_bgl_temp3 ~= 0)) _bgl_temp3 = "default";
    _bgl_temp2 = maybename; if (~~(_bgl_temp2 ~= 0)) _bgl_temp2 = _bgl_temp3;
    first=_bgl_temp2;
    print (string)c;
    print (string)label;
    print (string)first;
];
