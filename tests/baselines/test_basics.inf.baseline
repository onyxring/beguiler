!% -v5
!% -E1
Release 1;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglutil
;
object bgl
;
constant max = 100;
constant title = "Test";
[main a b c s ch flag i j;
    a = 5;
    b = 10;
    c=a + b;
    s="hello";
    ch = 'x';
    flag=true;
    a = a + 3;
    b = b - 1;
    c = c * 2;
     a++ ;
     b-- ;
    if (flag) {
        print (string)"yes";
    }
    else {
        print (string)"no";
    }
    for (i = 0 : i<10 : i ++) {
        print i;
    }
    while (a>0) {
         a-- ;
    }
    switch (c) {
        0:
            print (string)"zero";
        1, 2, 3:
            print (string)"low";
        4 to 10:
            print (string)"mid";
        default:
            print (string)"other";
    }
    for (j = 1 : j<=5 : j++) {
        print j;
    }
    print (string)title;
];
