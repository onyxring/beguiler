!% -G
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;
global _bgl_temp0;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[testArithmetic a b sum diff prod quot rem mixed neg;
    a = 10;
    b = 3;
    sum=a + b;
    diff=a - b;
    prod=a * b;
    quot=a / b;
    rem=a % b;
    mixed=(a + b) * (a - b);
    neg=-a;
];
[testComparison x y eq neq lt lte gt gte;
    x = 5;
    y = 10;
    eq=x == y;
    neq=x ~= y;
    lt=x < y;
    lte=x <= y;
    gt=x > y;
    gte=x >= y;
];
[testLogical a b andResult orResult notResult complex;
    a=true;
    b=false;
    andResult=a && b;
    orResult=a || b;
    notResult=~~a;
    complex=~~b;
];
[testCompound n;
    n = 10;
    n = n + 5;
    n = n - 2;
    n = n * 3;
    n = n / 4;
    n = n % 7;
];
[testIncDec i;
    i = 0;
     i++ ;
     i-- ;
     i++ ;
     i-- ;
];
[testTernary x tval;
    x = 7;
    if (x >= 0) _bgl_temp0 = x; else _bgl_temp0 = 0;
    tval=_bgl_temp0;
];
[testCast v n b;
    v = 42;
    n=v;
    b=n;
];
[printResult x;
    print x;
];
[testMixed a b r1 apb r2 r3;
    a = 4;
    b = 6;
    r1=a * a + b * b;
    apb=a + b;
    r2=apb * apb;
    r3=r2 - 1;
    printresult(r1);
    printresult(r3);
];
[testBitwise a b and_ or_;
    a = 12;
    b = 10;
    and_=a & b;
    or_=a | b;
    a = a & 7;
    b = b | 4;
];
[testExpressions;
    testarithmetic();
    testcomparison();
    testlogical();
    testcompound();
    testincdec();
    testternary();
    testcast();
    testmixed();
    testbitwise();
];
