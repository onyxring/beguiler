!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglutil
;
object bgl
  with util _bglutil
;
global g_isactive = true;
global g_isinactive;
global g_score = 0;
global g_moves;
global g_scratch;
constant max_rooms = 20;
constant max_items = 10;
constant title = "test";
array g_roomexits table 6;
array g_itemids table 10;
array g_primes table 2 3 5 7 11;
array g_fibonacci table 1 1 2 3 5 8;
[main first total;
    g_score = 0;
    g_moves = 0;
    g_scratch = 42;
    first =  g_primes-->(0+1) ;
    total =  g_primes-->(0+1) ;
];
