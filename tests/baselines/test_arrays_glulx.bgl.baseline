!% -G
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
class room
  class object
  with
    visits 0
;
room r1;
room r2;
object plainObj1;
object plainObj2;
array g_nums table 10 20 30 40 50;
array g_sized table 8;
array g_flags table true false true;
array g_buf buffer 32;
array g_short buffer 8;
object inventory
  with slots 0 0 0 0 0 0 ,
       count 0
;
[main i b last first middle last_c firstSh lastSh c;
    i= g_nums-->(0+1);
    b= g_flags-->(1+1);
    g_nums-->(0+1) = 42;
    g_flags-->(0+1) = false;
    g_sized-->(7+1) = 99;
    last= g_sized-->(7+1);
    g_buf->(0 + WORDSIZE) = 'H';
    g_buf->(1 + WORDSIZE) = 'e';
    g_buf->(15 + WORDSIZE) = 'X';
    g_buf->(31 + WORDSIZE) = '!';
    first= g_buf->(0 + WORDSIZE);
    middle= g_buf->(15 + WORDSIZE);
    last_c= g_buf->(31 + WORDSIZE);
    g_short->(0 + WORDSIZE) = 'a';
    g_short->(7 + WORDSIZE) = 'z';
    firstSh= g_short->(0 + WORDSIZE);
    lastSh= g_short->(7 + WORDSIZE);
    c=inventory.count;
];
