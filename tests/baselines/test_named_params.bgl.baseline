!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with util _bglutil
;
[greet name times;
    print (string)name;
];
[spawn name x y hostile;
    print (string)name;
];
[main;
    greet("Jim", 3);
    spawn("goblin", 10, 20, true);
];
