!% -v5
!% -E1
global _bgl_temp0;
global _bgl_temp1;
global _bgl_temp2;
global _bgl_temp3;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglutil
;
object bgl
  with util _bglutil
;
[main a b c maybename label first;
    a="hello";
    b="world";
    _bgl_temp0 = a; if (~~(_bgl_temp0 ~= 0)) _bgl_temp0 = b;
    c = _bgl_temp0;
    maybename="";
    _bgl_temp1 = maybename; if (~~(_bgl_temp1 ~= 0)) _bgl_temp1 = "unnamed";
    label=_bgl_temp1;
    _bgl_temp3 = label; if (~~(_bgl_temp3 ~= 0)) _bgl_temp3 = "default";
    _bgl_temp2 = maybename; if (~~(_bgl_temp2 ~= 0)) _bgl_temp2 = _bgl_temp3;
    first=_bgl_temp2;
    print (string)c;
    print (string)label;
    print (string)first;
];
