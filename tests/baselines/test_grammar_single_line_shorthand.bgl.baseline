!% -v5
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
constant story = "";
constant headline = "";
object whistle
  with perform [;
    print (string)"whistle";
  ]
;
[whistlesub;
                whistle.perform();
            ];
verb 'whistle'
    * noun -> whistle;
object hum
  with perform [;
    print (string)"hum";
  ]
;
[humsub;
                hum.perform();
            ];
verb 'hum' 'murmur'
    * noun -> hum;
object tap
  with perform [;
    print (string)"tap";
  ]
;
[tapsub;
                tap.perform();
            ];
verb 'tap'
    * noun -> tap;
verb 'knock'
    * noun -> tap;
[main;
];
