!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object whistle
  with handler [;
    print (string)"whistle";
  ]
;
[whistlesub;
                whistle.handler();
            ];
verb 'whistle'
    * noun -> whistle;
object hum
  with handler [;
    print (string)"hum";
  ]
;
[humsub;
                hum.handler();
            ];
verb 'hum' 'murmur'
    * noun -> hum;
object tap
  with handler [;
    print (string)"tap";
  ]
;
[tapsub;
                tap.handler();
            ];
verb 'tap'
    * noun -> tap;
verb 'knock'
    * noun -> tap;
[main;
];

    [main; 
        bglInit();
        _oldmain();
    ];

