!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;
Constant _BGL_LINQ_SCRATCH_SIZE = 32;
Array _bglFramePool --> 64;
Global _bglFrameTop = 0;
 [ _bglFrameAlloc size r;
    if (_bglFrameTop + size > 64) {
        print "^[Beguile runtime error: frame pool exhausted]^";
        quit;
    }
    r = _bglFrameTop;
    _bglFrameTop = _bglFrameTop + size;
    return _bglFramePool + (r * WORDSIZE);
 ];
 [ _bglFrameFree size;
    _bglFrameTop = _bglFrameTop - size;
 ];
 ! Allocate + initialize a local Beguile-declared word array of user-size `size`.
 ! Layout matches static tracked arrays: [header, data×size, length, magic].
 ! Returns a pointer at the header slot. Caller must free with _bglFrameFree(size+3)
 ! on every return path (driven by the function's cleanups list).
 ! Emitted only when the program includes <array>.
 [ _bglArrayLocalAlloc size r i;
    r = _bglFrameAlloc(size + 3);
    r-->0 = size + 2;
    for (i = 1: i <= size: i++) r-->i = 0;
    r-->(size + 1) = 0;
    r-->(size + 2) = $9084;
    return r;
 ];
 ! Plain variant for programs that don't include <array>: untracked layout
 ! [header=size, data×size]. Matches the global-array emission gated on the
 ! same arrayInUse flag. Caller frees with _bglFrameFree(size+1).
 [ _bglArrayLocalAllocPlain size r i;
    r = _bglFrameAlloc(size + 1);
    r-->0 = size;
    for (i = 1: i <= size: i++) r-->i = 0;
    return r;
 ];
 ! Allocate a local Beguile-declared BYTE array (array<char>) of `nbytes` data
 ! bytes. Layout matches the standalone hybrid buffer (`Array X buffer N`): the
 ! capacity/length WORD lives at -->0, the data bytes start at ->WORDSIZE. The
 ! frame slice is sized in words: one length word plus ceil(nbytes/WORDSIZE)
 ! data words. Caller frees the same word count via _bglByteArrayLocalFree(nbytes).
 [ _bglByteArrayLocalAlloc nbytes words r i;
    words = 1 + ((nbytes + WORDSIZE - 1) / WORDSIZE);
    r = _bglFrameAlloc(words);
    for (i = 0: i < words: i++) r-->i = 0;
    r-->0 = nbytes;   ! capacity, mirroring `buffer N`'s length word
    return r;
 ];
 [ _bglByteArrayLocalFree nbytes;
    _bglFrameFree(1 + ((nbytes + WORDSIZE - 1) / WORDSIZE));
 ];

    Array _bglLinqScratchA table _BGL_LINQ_SCRATCH_SIZE + 2;
    Array _bglLinqScratchB table _BGL_LINQ_SCRATCH_SIZE + 2;
    Global _bglLinqParity = 0;
    [ _bglLinqWrite;
        if(_bglLinqParity == 0) return _bglLinqScratchB;
        return _bglLinqScratchA;
    ];
    [ _bglLinqFlip;
        _bglLinqParity = 1 - _bglLinqParity;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;

    _bglLinqScratchA-->(_bglLinqScratchA-->0)     = $9084;
    _bglLinqScratchA-->(_bglLinqScratchA-->0 - 1) = 0;
    _bglLinqScratchB-->(_bglLinqScratchB-->0)     = $9084;
    _bglLinqScratchB-->(_bglLinqScratchB-->0 - 1) = 0;

];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[_bglArrayCompareAsc lhs rhs;
    
        if(lhs < rhs) return -1;
        if(lhs > rhs) return 1;
        return 0;
    
    return 0;
];
object _bglArray
  with rawGet [addr slot;
     return addr-->slot; 
    return 0;
  ],
       rawSet [addr slot v;
     addr-->slot = v; 
  ],
       get [obj prop n;
    
            if(metaclass(obj)==object) return obj.&prop-->n;
            return obj-->(n+1);
        
    return 0;
  ],
       set [obj prop n v;
    
            if(metaclass(obj)==object){ obj.&prop-->n = v; return; }
            obj-->(n+1) = v;
        
  ],
       isTracked [obj prop hdr;
     if(metaclass(obj)==object) rfalse; 
    hdr = self.rawget(obj,0);
    return self.rawget(obj,hdr)==36996&&self.rawget(obj,hdr-1)>=0;
  ],
       size [obj prop;
     if(metaclass(obj)==object) return obj.#prop/WORDSIZE; 
    if (self.istracked(obj,prop)) {
        return self.rawget(obj,0)-2;
    }
    return self.rawget(obj,0);
  ],
       length [obj prop;
     if(metaclass(obj)==object) return obj.#prop/WORDSIZE; 
    if (self.istracked(obj,prop)) {
        return self.rawget(obj,self.rawget(obj,0)-1);
    }
    return self.rawget(obj,0);
  ],
       setLength [obj prop n;
     if(metaclass(obj)==object) return; 
    if (self.istracked(obj,prop)) {
        if (n < 0) {
            print (string)"^[Beguile runtime error: setLength value exceeds signed range (max 32767 on Z, 2^31-1 on Glulx)]^";
             quit; 
        }
        self.set(obj, prop, self.size(obj,prop), n);
    }
  ],
       indexOf [obj prop val sz t;
    sz=self.size(obj,prop);
    for (t = 0 : t < sz : t++) {
        if (self.get(obj,prop,t)==val) {
            return t;
        }
    }
    return -1;
  ],
       clear [obj prop sz t;
    sz=self.size(obj,prop);
    for (t = 0 : t < sz : t++) {
        self.set(obj, prop, t, 0);
    }
    self.setLength(obj, prop, 0);
  ],
       swap [obj prop pos1 pos2 tmp;
    tmp = self.get(obj,prop,pos1);
    self.set(obj, prop, pos1, self.get(obj,prop,pos2));
    self.set(obj, prop, pos2, tmp);
  ],
       reverse [obj prop len half i;
    len=self.length(obj,prop);
    half=len / 2;
    for (i = 0 : i < half : i++) {
        self.swap(obj, prop, i, len - 1 - i);
    }
  ],
       append [obj prop val len;
    len=self.length(obj,prop);
    if (len >= self.size(obj,prop)) {
        return false;
    }
    self.set(obj, prop, len, val);
    self.setLength(obj, prop, len + 1);
    return true;
  ],
       insert [obj prop pos val len i;
    len=self.length(obj,prop);
    if (len >= self.size(obj,prop)) {
        return false;
    }
    if (pos < 0 || pos > len) {
        return false;
    }
    for (i = len : i > pos : i--) {
        self.set(obj, prop, i, self.get(obj,prop,i - 1));
    }
    self.set(obj, prop, pos, val);
    self.setLength(obj, prop, len + 1);
    return true;
  ],
       prepend [obj prop val;
    return self.insert(obj,prop,0,val);
  ],
       remove [obj prop pos len i;
    len=self.length(obj,prop);
    if (pos < 0 || pos >= len) {
        return;
    }
    for (i = pos : i < len - 1 : i++) {
        self.set(obj, prop, i, self.get(obj,prop,i + 1));
    }
    self.set(obj, prop, len - 1, 0);
    self.setLength(obj, prop, len - 1);
  ],
       removeValue [obj prop val pos len;
    pos = 0;
    len=self.length(obj,prop);
    while (pos < len) {
        if (self.get(obj,prop,pos)==val) {
            self.remove(obj, prop, pos);
            len = self.length(obj,prop);
        }
        else {
             pos++ ;
        }
    }
  ],
       push [obj prop val;
    self.insert(obj, prop, 0, val);
  ],
       pop [obj prop v;
    if (self.length(obj,prop) == 0) {
        return 0;
    }
    v = self.get(obj,prop,0);
    self.remove(obj, prop, 0);
    return v;
  ],
       dequeue [obj prop;
    return self.pop(obj,prop);
  ],
       enqueue [obj prop val;
    self.append(obj, prop, val);
  ],
       peek [obj prop;
    if (self.length(obj,prop) == 0) {
        return 0;
    }
    return self.get(obj,prop,0);
  ],
       peekEnd [obj prop len;
    len=self.length(obj,prop);
    if (len == 0) {
        return 0;
    }
    return self.get(obj,prop,len - 1);
  ],
       popEnd [obj prop len v;
    len=self.length(obj,prop);
    if (len == 0) {
        return 0;
    }
    v = self.get(obj,prop,len - 1);
    self.remove(obj, prop, len - 1);
    return v;
  ],
       sort [obj prop compare len i key j;
    len=self.length(obj,prop);
    for (i = 1 : i < len : i++) {
        key = self.get(obj,prop,i);
        j=i - 1;
        while (j >= 0 && compare(self.get(obj,prop,j),key) > 0) {
            self.set(obj, prop, j + 1, self.get(obj,prop,j));
             j-- ;
        }
        self.set(obj, prop, j + 1, key);
    }
  ],
       filter [obj prop pred dst cap writeCount srcLen i elem;
    dst = _bgllinqwrite();
    cap = 32;
    writeCount = 0;
    srcLen=self.length(obj,prop);
    for (i = 0 : i < srclen : i++) {
        elem = self.get(obj,prop,i);
        if (pred(elem)) {
            if (writecount >= cap) {
                
                        print "^[Beguile runtime error: filter() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                        quit;
                    
            }
            dst-->(writecount+1) = elem;
             writecount++ ;
        }
    }
    _bglArray.setLength(dst, 0, writeCount);
    _bgllinqflip();
    return dst;
  ],
       first [obj prop;
    if (self.length(obj,prop) == 0) {
        return 0;
    }
    return self.get(obj,prop,0);
  ],
       last [obj prop len;
    len=self.length(obj,prop);
    if (len == 0) {
        return 0;
    }
    return self.get(obj,prop,len - 1);
  ],
       any [obj prop pred len i;
    len=self.length(obj,prop);
    for (i = 0 : i < len : i++) {
        if (pred(self.get(obj,prop,i))) {
            return true;
        }
    }
    return false;
  ],
       all [obj prop pred len i;
    len=self.length(obj,prop);
    for (i = 0 : i < len : i++) {
        if (~~pred(self.get(obj,prop,i))) {
            return false;
        }
    }
    return true;
  ],
       map [obj prop f dst cap srcLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    if (srclen > cap) {
        
                print "^[Beguile runtime error: map() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < srclen : i++) {
        dst-->(i+1) = f(self.get(obj,prop,i));
    }
    _bglArray.setLength(dst, 0, srcLen);
    _bgllinqflip();
    return dst;
  ],
       take [obj prop n dst cap srcLen outLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    outLen=n;
    if (outlen < 0) {
        outLen = 0;
    }
    if (outlen > srclen) {
        outLen = srcLen;
    }
    if (outlen > cap) {
        
                print "^[Beguile runtime error: take() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < outlen : i++) {
        dst-->(i+1) = self.get(obj,prop,i);
    }
    _bglArray.setLength(dst, 0, outLen);
    _bgllinqflip();
    return dst;
  ],
       skip [obj prop n dst cap srcLen start outLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    start=n;
    if (start < 0) {
        start = 0;
    }
    if (start > srclen) {
        start = srcLen;
    }
    outLen=srclen - start;
    if (outlen > cap) {
        
                print "^[Beguile runtime error: skip() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < outlen : i++) {
        dst-->(i+1) = self.get(obj,prop,start + i);
    }
    _bglArray.setLength(dst, 0, outLen);
    _bgllinqflip();
    return dst;
  ],
       takeWhile [obj prop pred dst cap srcLen outLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    outLen = 0;
    for (i = 0 : i < srclen : i++) {
        if (~~pred(self.get(obj,prop,i))) {
            break;
        }
        if (outlen >= cap) {
            
                    print "^[Beguile runtime error: takeWhile() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                    quit;
                
        }
        dst-->(outlen+1) = self.get(obj,prop,i);
         outlen++ ;
    }
    _bglArray.setLength(dst, 0, outLen);
    _bgllinqflip();
    return dst;
  ],
       skipWhile [obj prop pred dst cap srcLen start outLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    start = 0;
    while (start < srclen && pred(self.get(obj,prop,start))) {
         start++ ;
    }
    outLen=srclen - start;
    if (outlen > cap) {
        
                print "^[Beguile runtime error: skipWhile() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < outlen : i++) {
        dst-->(i+1) = self.get(obj,prop,start + i);
    }
    _bglArray.setLength(dst, 0, outLen);
    _bgllinqflip();
    return dst;
  ],
       distinct [obj prop dst cap srcLen outLen i elem seen j;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    outLen = 0;
    for (i = 0 : i < srclen : i++) {
        elem = self.get(obj,prop,i);
        seen=false;
        for (j = 0 : j < outlen : j++) {
            if ( dst-->(j+1) ==elem) {
                seen = true;
                break;
            }
        }
        if (~~seen) {
            if (outlen >= cap) {
                
                        print "^[Beguile runtime error: distinct() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                        quit;
                    
            }
            dst-->(outlen+1) = elem;
             outlen++ ;
        }
    }
    _bglArray.setLength(dst, 0, outLen);
    _bgllinqflip();
    return dst;
  ],
       orderBy [obj prop compare dst cap srcLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    if (srclen > cap) {
        
                print "^[Beguile runtime error: orderBy() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < srclen : i++) {
        dst-->(i+1) = self.get(obj,prop,i);
    }
    _bglArray.setLength(dst, 0, srcLen);
    self.sort(dst, 0, compare);
    _bgllinqflip();
    return dst;
  ]
;
[sumDown n acc rest;
    acc = _bglArrayLocalAlloc(4);
    if (n <= 0) {
        _bglFrameFree(7);
        return 0;
    }
    _bglArray.append(acc, 0, n);
    rest=sumdown(n - 1);
    _bglFrameFree(7);
    return  acc-->(0+1)  + rest;
    _bglFrameFree(7);
];
[useTwoLocals a b first second;
    first = _bglArrayLocalAlloc(3);
    second = _bglArrayLocalAlloc(3);
    _bglArray.append(first, 0, a);
    _bglArray.append(first, 0, b);
    _bglArray.append(second, 0, a + b);
    _bglFrameFree(6);
    _bglFrameFree(6);
    return  first-->(0+1)  +  first-->(1+1)  +  second-->(0+1) ;
    _bglFrameFree(6);
    _bglFrameFree(6);
];
[earlyReturn flag buf;
    buf = _bglArrayLocalAlloc(5);
    _bglArray.append(buf, 0, 100);
    if (flag) {
        _bglFrameFree(8);
        return  buf-->(0+1) ;
    }
    _bglArray.append(buf, 0, 200);
    _bglFrameFree(8);
    return  buf-->(1+1) ;
    _bglFrameFree(8);
];
[sumAll data total i;
    total = 0;
    for (i = 0 : i < _bglArray.length(data, 0) : i++) {
        total = total +  data-->(i+1) ;
    }
    return total;
];
[listInitLocal primes;
    primes = _bglArrayLocalAlloc(5);
    primes-->1 = 2;
    primes-->2 = 3;
    primes-->3 = 5;
    primes-->4 = 7;
    primes-->5 = 11;
    primes-->6 = 5;
    _bglFrameFree(8);
    return _bglArray.length(primes, 0) * 100 + sumall(primes);
    _bglFrameFree(8);
];
[localByteArray buf c0 c1;
    buf = _bglByteArrayLocalAlloc(8);
    buf->(0 + WORDSIZE) = 'X';
    buf->(1 + WORDSIZE) = 'Y';
    c0= buf->(0 + WORDSIZE);
    c1= buf->(1 + WORDSIZE);
    if (c0=='X' && c1=='Y') {
        _bglByteArrayLocalFree(8);
        return 777;
    }
    _bglByteArrayLocalFree(8);
    return 0;
    _bglByteArrayLocalFree(8);
];
[main;
    print sumdown(5);
    print usetwolocals(3,4);
    print earlyreturn(true);
    print earlyreturn(false);
    print listinitlocal();
    print localbytearray();
];
