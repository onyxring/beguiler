!% -v5
!% -E1
Constant _BGL_LINQ_SCRATCH_SIZE = 32;
Array _bglFramePool --> 64;
Global _bglFrameTop = 0;
 [ _bglFrameAlloc size r;
    if (_bglFrameTop + size > 64) {
        print "^[Beguile runtime error: frame pool exhausted]^";
        quit;
    }
    r = _bglFrameTop;
    _bglFrameTop = _bglFrameTop + size;
    return _bglFramePool + (r * WORDSIZE);
 ];
 [ _bglFrameFree size;
    _bglFrameTop = _bglFrameTop - size;
 ];
 ! Allocate + initialize a local Beguile-declared word array of user-size `size`.
 ! Layout matches static tracked arrays: [header, data×size, length, magic].
 ! Returns a pointer at the header slot. Caller must free with _bglFrameFree(size+3)
 ! on every return path (driven by the function's cleanups list).
 [ _bglArrayLocalAlloc size r i;
    r = _bglFrameAlloc(size + 3);
    r-->0 = size + 2;
    for (i = 1: i <= size: i++) r-->i = 0;
    r-->(size + 1) = 0;
    r-->(size + 2) = $9084;
    return r;
 ];

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];


    Array _bglLinqScratchA --> _BGL_LINQ_SCRATCH_SIZE + 2;
    Array _bglLinqScratchB --> _BGL_LINQ_SCRATCH_SIZE + 2;
    Global _bglLinqParity = 0;
    [ _bglLinqRead;
        if(_bglLinqParity == 0) return _bglLinqScratchA;
        return _bglLinqScratchB;
    ];
    [ _bglLinqWrite;
        if(_bglLinqParity == 0) return _bglLinqScratchB;
        return _bglLinqScratchA;
    ];
    [ _bglLinqFlip;
        _bglLinqParity = 1 - _bglLinqParity;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;

    _bglLinqScratchA-->(_bglLinqScratchA-->0)     = $9084;
    _bglLinqScratchA-->(_bglLinqScratchA-->0 - 1) = 0;
    _bglLinqScratchB-->(_bglLinqScratchB-->0)     = $9084;
    _bglLinqScratchB-->(_bglLinqScratchB-->0 - 1) = 0;

];
object _bglArray
  with isTracked [arr;
    return  arr-->( arr-->(-1+1) -1+1) ==36996&& arr-->( arr-->(-1+1) -2+1) >=0;
  ],
       size [arr;
    if (self.istracked(arr)) {
        return  arr-->(-1+1) -2;
    }
    return  arr-->(-1+1) ;
  ],
       length [arr;
    if (self.istracked(arr)) {
        return  arr-->( arr-->(-1+1) -2+1) ;
    }
    return  arr-->(-1+1) ;
  ],
       setLength [arr n;
    if (self.istracked(arr)) {
        if (n<0) {
            print (string)"^[Beguile runtime error: setLength value exceeds signed range (max 32767 on Z, 2^31-1 on Glulx)]^";
             quit; 
        }
        arr-->(_bglArray.size(arr)+1) = n;
    }
  ],
       indexOf [arr val sz t;
    sz=_bglArray.size(arr);
    for (t = 0 : t < sz : t++) {
        if ( arr-->(t+1) ==val) {
            return t;
        }
    }
    return -1;
  ],
       clear [arr sz t;
    sz=_bglArray.size(arr);
    for (t = 0 : t < sz : t++) {
        arr-->(t+1) = 0;
    }
    _bglArray.setLength(arr, 0);
  ],
       swap [arr pos1 pos2 tmp;
    tmp =  arr-->(pos1+1) ;
    arr-->(pos1+1) =  arr-->(pos2+1);
    arr-->(pos2+1) = tmp;
  ],
       reverse [arr len half i;
    len=_bglArray.length(arr);
    half=len / 2;
    for (i = 0 : i < half : i++) {
        self.swap(arr, i, len - 1 - i);
    }
  ],
       append [arr val len;
    len=_bglArray.length(arr);
    if (len >= _bglArray.size(arr)) {
        return false;
    }
    arr-->(len+1) = val;
    _bglArray.setLength(arr, len + 1);
    return true;
  ],
       insert [arr pos val len i;
    len=_bglArray.length(arr);
    if (len >= _bglArray.size(arr)) {
        return false;
    }
    if (pos<0 || pos > len) {
        return false;
    }
    for (i = len : i > pos : i--) {
        arr-->(i+1) =  arr-->(i - 1+1);
    }
    arr-->(pos+1) = val;
    _bglArray.setLength(arr, len + 1);
    return true;
  ],
       prepend [arr val;
    return self.insert(arr,0,val);
  ],
       remove [arr pos len i;
    len=_bglArray.length(arr);
    if (pos<0 || pos >= len) {
        return;
    }
    for (i = pos : i < len - 1 : i++) {
        arr-->(i+1) =  arr-->(i + 1+1);
    }
    arr-->(len - 1+1) = 0;
    _bglArray.setLength(arr, len - 1);
  ],
       removeValue [arr val pos len;
    pos = 0;
    len=_bglArray.length(arr);
    while (pos < len) {
        if ( arr-->(pos+1) ==val) {
            self.remove(arr, pos);
            len = _bglArray.length(arr);
        }
        else {
             pos++ ;
        }
    }
  ],
       push [arr val;
    self.insert(arr, 0, val);
  ],
       pop [arr v;
    if (_bglArray.length(arr)==0) {
        return 0;
    }
    v =  arr-->(0+1) ;
    self.remove(arr, 0);
    return v;
  ],
       dequeue [arr;
    return self.pop(arr);
  ],
       enqueue [arr val;
    self.append(arr, val);
  ],
       peek [arr;
    if (_bglArray.length(arr)==0) {
        return 0;
    }
    return  arr-->(0+1) ;
  ],
       peekEnd [arr len;
    len=_bglArray.length(arr);
    if (len==0) {
        return 0;
    }
    return  arr-->(len - 1+1) ;
  ],
       popEnd [arr len v;
    len=_bglArray.length(arr);
    if (len==0) {
        return 0;
    }
    v =  arr-->(len - 1+1) ;
    self.remove(arr, len - 1);
    return v;
  ],
       sort [arr compare len i key j;
    len=_bglArray.length(arr);
    for (i = 1 : i < len : i++) {
        key =  arr-->(i+1) ;
        j=i - 1;
        while (j>=0 && compare( arr-->(j+1) ,key)>0) {
            arr-->(j + 1+1) =  arr-->(j+1);
             j-- ;
        }
        arr-->(j + 1+1) = key;
    }
  ],
       filter [src pred dst cap writeCount srcLen i elem;
    
            if(_bglLinqParity == 0) dst = _bglLinqScratchB;
            else                    dst = _bglLinqScratchA;
            cap = _BGL_LINQ_SCRATCH_SIZE;
        
    writeCount = 0;
    srcLen=_bglArray.length(src);
    for (i = 0 : i < srclen : i++) {
        elem =  src-->(i+1) ;
        if (pred(elem)) {
            if (writecount >= cap) {
                
                        print "^[Beguile runtime error: filter() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                        quit;
                    
            }
            dst-->(writecount+1) = elem;
             writecount++ ;
        }
    }
    _bglArray.setLength(dst, writeCount);
     _bglLinqParity = 1 - _bglLinqParity; 
    return dst;
  ],
       map [src f dst cap srcLen i;
    
            if(_bglLinqParity == 0) dst = _bglLinqScratchB;
            else                    dst = _bglLinqScratchA;
            cap = _BGL_LINQ_SCRATCH_SIZE;
        
    srcLen=_bglArray.length(src);
    if (srclen > cap) {
        
                print "^[Beguile runtime error: map() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < srclen : i++) {
        dst-->(i+1) = f( src-->(i+1) );
    }
    _bglArray.setLength(dst, srcLen);
     _bglLinqParity = 1 - _bglLinqParity; 
    return dst;
  ]
;
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[_bglArrayCompareAsc lhs rhs;
    
        if(lhs < rhs) return -1;
        if(lhs > rhs) return 1;
        return 0;
    
    return 0;
];
[sumDown n acc rest;
    acc = _bglArrayLocalAlloc(4);
    if (n<=0) {
        _bglFrameFree(7);
        return 0;
    }
    _bglArray.append(acc, n);
    rest=sumdown(n - 1);
    _bglFrameFree(7);
    return  acc-->(0+1)  + rest;
    _bglFrameFree(7);
];
[useTwoLocals a b first second;
    first = _bglArrayLocalAlloc(3);
    second = _bglArrayLocalAlloc(3);
    _bglArray.append(first, a);
    _bglArray.append(first, b);
    _bglArray.append(second, a + b);
    _bglFrameFree(6);
    _bglFrameFree(6);
    return  first-->(0+1)  +  first-->(1+1)  +  second-->(0+1) ;
    _bglFrameFree(6);
    _bglFrameFree(6);
];
[earlyReturn flag buf;
    buf = _bglArrayLocalAlloc(5);
    _bglArray.append(buf, 100);
    if (flag) {
        _bglFrameFree(8);
        return  buf-->(0+1) ;
    }
    _bglArray.append(buf, 200);
    _bglFrameFree(8);
    return  buf-->(1+1) ;
    _bglFrameFree(8);
];
[main;
    print sumdown(5);
    print usetwolocals(3,4);
    print earlyreturn(true);
    print earlyreturn(false);
];
