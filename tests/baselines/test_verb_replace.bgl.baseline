!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object quaff
  with handler [;
    print (string)"quaff";
  ]
;
[quaffsub;
                quaff.handler();
            ];
verb 'quaff'
    * noun -> quaff;
extend 'quaff' replace
    * 'deeply' noun -> quaff;
[main;
];
extend 'take' replace
    * 'firmly' noun -> take;
verb 'pilfer'
    * noun -> take;

    [main; 
        bglInit();
        _oldmain();
    ];

