!% -v5
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[apply f x;
    return f(x);
];
[apply2 f g x;
    return f(g(x));
];
class deep
  with
    compute[n total i j;
        total = 0;
        for (i = 0 : i<3 : i++) {
            j = 0;
            while (j<2) {
                if (i == j) {
                    if (n>0) {
                        total = total + n + i + j;
                    }
                    else {
                        total = total - i - j;
                    }
                }
                j = j + 1;
            }
        }
        return total;
    ]
;
global d;
[main x y z;
    x=apply(_bglLambda_0,5);
    print x;
    y=apply2(_bglLambda_2,_bglLambda_3,4);
    print y;
    z=apply(_bglLambda_4,7);
    print z;
    print d.compute(10);
    print d.compute(-1);
];
[_bglLambda_1 b;
    return b * 2;
];
[_bglLambda_0 a inner;
    inner=apply(_bglLambda_1,a);
    return inner + 1;
];
[_bglLambda_2 a;
    return a + 1;
];
[_bglLambda_3 b;
    return b * 3;
];
[_bglLambda_6 c;
    return c + 100;
];
[_bglLambda_5 b;
    return apply(_bglLambda_6,b);
];
[_bglLambda_4 a;
    return apply(_bglLambda_5,a);
];
