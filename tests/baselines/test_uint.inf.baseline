object _bglmath
  with unsignedcompare [x y u v;
    if (x == y) {
        return 0;
    }
    if (x<0 && y>=0) {
        return 1;
    }
    if (x>=0 && y<0) {
        return -1;
    }
    u=x & 32767;
    v=y & 32767;
    if (u > v) {
        return 1;
    }
    return -1;
  ],
       shiftleft [i numbits;
    return i * self.pow(2,numbits);
  ],
       shiftright [i numbits;
    return i / self.pow(2,numbits);
  ],
       abs [p;
    if (p<0) _bgl_temp0 = -p; else _bgl_temp0 = p;
    return _bgl_temp0;
  ],
       unsigneddiv [a b lowhalf hq hr combined;
    if (b==0) {
        return 0;
    }
    if (a>=0 && b>0) {
        return a / b;
    }
    if (b<0) {
        if (self.unsignedcompare(a,b)>=0) _bgl_temp1 = 1; else _bgl_temp1 = 0;
        return _bgl_temp1;
    }
    lowhalf=a & 32767;
    hq=32767 / b;
    hr=32767 % b + 1;
    if (hr >= b) {
        hq = hq + 1;
        hr = hr - b;
    }
    combined=lowhalf + hr;
    if (combined>=0) {
        return hq + combined / b;
    }
    return hq + self.unsigneddiv(combined,b);
  ],
       unsignedmod [a b;
    if (b==0) {
        return 0;
    }
    if (a>=0 && b>0) {
        return a % b;
    }
    return a - self.unsigneddiv(a,b) * b;
  ],
       pow [i p retval t;
    if (p==0) {
        return 1;
    }
    retval=i;
    if (p<0) {
        for (t = 0 : t < (-p) - 1 : t++) {
            retval = retval / i;
        }
        return retval;
    }
    for (t = 0 : t < p - 1 : t++) {
        retval = retval * i;
    }
    return retval;
  ]
;
[_bglprintuint v digits buf0 buf1 buf2 buf3 buf4 buf5 buf6 buf7 buf8 buf9 tmp d;
