!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object bar
  with before [;
    if (noun~=0) {
        forwardobj.field = forwardobj.field + 2;
    }
  ],
       afterCheck [flag;
    flag=false;
    if (~~flag) {
        anotherforward.field = anotherforward.field + 3;
    }
  ]
;
object forwardObj
  with field 0
;
object anotherForward
  with field 0
;
[main;
    bar.before();
    bar.aftercheck();
];
