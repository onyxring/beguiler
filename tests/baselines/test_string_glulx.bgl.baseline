[exerciseAssign s1 s2 s3;
    s1 = _bglStr.new();
    s1.setFromLit("hello");
    s2 = _bglStr.new();
    s2.setFromStr(s1);
    s3 = _bglStr.new();
    s3.setFromLit("interp {s1} world");
    s1.free();
    s2.free();
    s3.free();
];
[exerciseEquality s eq_lit o eq_str code;
    s = _bglStr.new();
    s.setFromLit("test");
    eq_lit=(s.equalsLit("test"));
    o = _bglStr.new();
    o.setFromLit("test");
    eq_str=(s.equalsStr(o));
    code = 0;
    _bgl_sw = s;
    if ((_bgl_sw.equalsLit("hello"))) {
        code = 1;
    }
    else if ((_bgl_sw.equalsLit("test"))) {
        code = 2;
    }
    else {
        code = 99;
    }
    s.free();
    o.free();
];
[exerciseConcat s1 s2 c;
    s1 = _bglStr.new();
    s1.setFromLit("foo");
    s2 = _bglStr.new();
    s2.setFromLit("bar");
    c = _bglStr.new();
    c.setFromStr(s1.append(s2));
    c.setFromStr(s1.append("literal"));
    c.setFromStr(_bglStr.new("literal").append(s1));
    c.setFromStr(_bglStr.new("literal").appendChar('X'));
    s1.free();
    s2.free();
    c.free();
];
[exerciseNullable s1 s2 c present;
    s1 = _bglStr.new();
    s1.setFromLit("hi");
    s2 = _bglStr.new();
    _bgl_temp1 = s2; if (~~(_bgl_temp1 ~= 0)) _bgl_temp1 = "fallback";
    _bgl_temp0 = s1; if (~~(_bgl_temp0 ~= 0)) _bgl_temp0 = _bgl_temp1;
    c = _bglStr.new();
    c.setFromLit(_bgl_temp0);
    present=s1 ~= 0;
    s1.free();
    s2.free();
    c.free();
];
[exerciseMethods s t len pos sw ew has emp;
    s = _bglStr.new();
    s.setFromLit("Hello, World");
    s.print();
    t = _bglStr.new();
    t.setFromStr(s.append(" suffix"));
    t.setFromStr(s.appendChar('!'));
    t.setFromStr(s.prepend("prefix "));
    t.setFromStr(s.toUpper());
    t.setFromStr(s.toLower());
    t.setFromStr(s.trim());
    t.setFromStr(s.trimLeft());
    t.setFromStr(s.trimRight());
    t.setFromStr(s.reverse());
    t.setFromStr(s.mid(2, 5));
    t.setFromStr(s.left(3));
    t.setFromStr(s.right(4));
    t.setFromStr(s.insert(1, "X"));
    t.setFromStr(s.delete(0, 2));
    t.setFromStr(s.replace("Hello", "Greetings"));
    t.setFromStr(s.replaceAll("o", "0"));
    t.setFromStr(s.format("[$0]"));
    t.setFromStr(s.format("[$0:$1]", "extra"));
    t.setFromStr(s.format("[$0:$1:$2]", "a", "b"));
    len=s.getLength();
    pos=s.indexOf("World", 0);
    sw=s.startsWith("Hello", false);
    ew=s.endsWith("World", false);
    has=s.contains(",");
    emp=s.isEmpty();
    s.capture();
    print (string)"captured-content";
    s.release();
    s.free();
    t.free();
];
[main;
    exerciseassign();
    exerciseequality();
    exerciseconcat();
    exercisenullable();
    exercisemethods();
];
