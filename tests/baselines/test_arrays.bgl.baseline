!% -v5
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
class room
  class object
  with
    visits 0
;
room r1;
room r2;
global plainObj1;
global plainObj2;
array g_nums table 1 2 3 4 5;
array g_sized table 10;
array g_flags table true false true;
array g_objs table plainobj1 plainobj2;
array g_rooms table r1 r2;
array g_buf buffer 32;
object inventory
  with slots 0 0 0 0 0 0 ,
       count 0
;
[main i b r o c ch;
    i= g_nums-->(0+1);
    b= g_flags-->(1+1);
    r =  g_rooms-->(0+1) ;
    o =  g_objs-->(0+1);
    g_nums-->(0+1) = 42;
    g_flags-->(0+1) = false;
    g_rooms-->(0+1) = r2;
    g_objs-->(0+1) = r1;
    c=inventory.count;
    ch= g_buf->(0+2);
];
