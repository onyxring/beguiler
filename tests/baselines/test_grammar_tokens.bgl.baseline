!% -G
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
constant story = "";
constant headline = "";
[inScope;
    return true;
];
[setScope;
    return true;
];
[myFilter;
    return true;
];
object measure
  with perform [;
    print (string)"Measured.";
  ]
;
[measuresub;
                measure.perform();
            ];
verb 'measure'
    * anynumber -> measure;
object replenish
  with perform [;
    print (string)"Replenished.";
  ]
;
[replenishsub;
                replenish.perform();
            ];
verb 'replenish'
    * container -> replenish;
verb 'chat'
    * animate 'about' topic -> replenish;
object fiddle
  with perform [;
    print (string)"Fiddled.";
  ]
;
[fiddlesub;
                fiddle.perform();
            ];
verb 'fiddle'
    * myfilter -> fiddle;
object grab
  with perform [;
    print (string)"Grabbed.";
  ]
;
[grabsub;
                grab.perform();
            ];
verb 'grab'
    * noun=inscope -> grab;
object seek
  with perform [;
    print (string)"Sought.";
  ]
;
[seeksub;
                seek.perform();
            ];
verb 'seek'
    * scope=setscope -> seek;
object pour
  with perform [;
    print (string)"Poured.";
  ]
;
[poursub;
                pour.perform();
            ];
verb 'pour'
    * container noun=inscope -> pour;
