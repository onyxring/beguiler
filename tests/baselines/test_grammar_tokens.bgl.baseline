!% -G
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
[__glkHook _vararg_count api args retval;
    @copy sp api;
    args=_vararg_count - 1;
    @glk api args retval;
    return retval;
];
object _glulx
;
object _bglUtil
;
object bgl
  with glulx _glulx,
       utilities _bglutil
;
constant story = "";
constant headline = "";
[inScope;
    return true;
];
[setScope;
    return true;
];
[myFilter;
    return true;
];
object measure
  with perform [;
    print (string)"Measured.";
  ]
;
[measuresub;
                measure.perform();
            ];
verb 'measure'
    * anynumber -> measure;
object replenish
  with perform [;
    print (string)"Replenished.";
  ]
;
[replenishsub;
                replenish.perform();
            ];
verb 'replenish'
    * container -> replenish;
verb 'chat'
    * animate 'about' topic -> replenish;
object fiddle
  with perform [;
    print (string)"Fiddled.";
  ]
;
[fiddlesub;
                fiddle.perform();
            ];
verb 'fiddle'
    * myfilter -> fiddle;
object grab
  with perform [;
    print (string)"Grabbed.";
  ]
;
[grabsub;
                grab.perform();
            ];
verb 'grab'
    * noun=inscope -> grab;
object seek
  with perform [;
    print (string)"Sought.";
  ]
;
[seeksub;
                seek.perform();
            ];
verb 'seek'
    * scope=setscope -> seek;
object pour
  with perform [;
    print (string)"Poured.";
  ]
;
[poursub;
                pour.perform();
            ];
verb 'pour'
    * container noun=inscope -> pour;
