!% -G
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[inScope;
    return true;
];
[setScope;
    return true;
];
[myFilter;
    return true;
];
object measure
  with handler [;
    print (string)"Measured.";
  ]
;
[measuresub;
                measure.handler();
            ];
verb 'measure'
    * anynumber -> measure;
object replenish
  with handler [;
    print (string)"Replenished.";
  ]
;
[replenishsub;
                replenish.handler();
            ];
verb 'replenish'
    * container -> replenish;
verb 'chat'
    * animate 'about' topic -> replenish;
object fiddle
  with handler [;
    print (string)"Fiddled.";
  ]
;
[fiddlesub;
                fiddle.handler();
            ];
verb 'fiddle'
    * myfilter -> fiddle;
object grab
  with handler [;
    print (string)"Grabbed.";
  ]
;
[grabsub;
                grab.handler();
            ];
verb 'grab'
    * noun=inscope -> grab;
object seek
  with handler [;
    print (string)"Sought.";
  ]
;
[seeksub;
                seek.handler();
            ];
verb 'seek'
    * scope=setscope -> seek;
object pour
  with handler [;
    print (string)"Poured.";
  ]
;
[poursub;
                pour.handler();
            ];
verb 'pour'
    * container noun=inscope -> pour;

    [main; 
        bglInit();
        _oldmain();
    ];

