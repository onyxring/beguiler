!% -v5
!% -E1
Constant beguiler       = 1000;
Constant beguilerMajor  = 1;
Constant beguilerMinor  = 0;
Constant beguilerPatch  = 0;
global _bgl_sw;
[bglInit;
];

Array _bglWorldBuf --> 257;   ! capacity word (-->0) + 256 object slots

object bglWorld
    with getAll [ o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o) {
            if (i > 256) break;
            _bglWorldBuf-->i = o;
            i++;
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    getFiltered [ pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o) {
            if (i > 256) break;
            if (indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    inParent [ parent pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o in parent) {
            if (i > 256) break;
            if (pred == 0 || indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    ofClass [ cls pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o ofclass cls) {
            if (i > 256) break;
            if (pred == 0 || indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ]
;

[main val;
    val=7;
    _bgl_sw = val;
    if (_bgl_sw == 0) {
        print (string)"zero";
    }
    else if (_bgl_sw == 1 || _bgl_sw == 2 || _bgl_sw == 3) {
        print (string)"low";
    }
    else if ((_bgl_sw >= 4 && _bgl_sw <= 6)) {
        print (string)"mid";
    }
    else if ((_bgl_sw >= 7 && _bgl_sw <= 9)) {
        print (string)"high";
    }
    else if ((_bgl_sw > 9)) {
        print (string)"over nine";
    }
    else {
        print (string)"negative";
    }
    switch (val) {
        1, 2:
            print (string)"one or two";
        3 to 5:
            print (string)"three to five";
        6, 7 to 9:
            print (string)"six or seven to nine";
    }
];
