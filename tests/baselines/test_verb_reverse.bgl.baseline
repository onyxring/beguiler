!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object give2
  with handler [;
    print (string)"give";
  ]
;
[give2sub;
                give2.handler();
            ];
extend 'give'
    * held 'to' creature -> give2
    * creature held -> give2 reverse;
[main;
];
verb 'donate'
    * held 'to' creature -> Give2
    * creature held -> Give2 reverse;

    [main; 
        bglInit();
        _oldmain();
    ];

