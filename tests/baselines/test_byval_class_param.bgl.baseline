!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
class vec
  with
    x,
    y,
    _opeq[v;
        self.x=v.x;
        self.y=v.y;
        return self;
    ]
;
class window
  with
    w,
    h,
    =[v;
        self.w=v.w;
        self.h=v.h;
        return self;
    ]
;
vec srcVec;
window srcWin;
[mutateVec v;
    _bglParam_mutatevec_v._opeq(v);
    _bglParam_mutatevec_v.x = 999;
];
[mutateWin w;
    w.w = 999;
];
class mat
  with
    a,
    b,
    =[m;
        self.a=m.a;
        self.b=m.b;
        return self;
    ],
    dot[other;
        _bglParam_Mat_dot_other._opeq(other);
        _bglParam_Mat_dot_other.x = 0;
        return self.a * _bglParam_Mat_dot_other.y;
    ]
;
mat srcMat;
[main d;
    srcvec.x = 1;
    srcvec.y = 2;
    mutatevec(srcvec);
    srcwin.w = 100;
    srcwin.h = 200;
    mutatewin(srcwin);
    srcmat.a = 10;
    srcmat.b = 20;
    d=srcmat.dot(srcvec);
];
vec _bglParam_mutatevec_v;
vec _bglParam_Mat_dot_other;
