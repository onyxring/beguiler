!% -v5
!% -E1
Release 1;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with util _bglutil
;
constant MAX = 100;
constant TITLE = "Test";
constant RAW_MSG = "raw \n stays literal and \t too";
constant RAW_WITH_QUOTE = "has a ""quoted"" word";
[main a b c s ch flag autoInt autoChar i j;
    a = 5;
    b = 10;
    c=a + b;
    s="hello";
    ch = 'x';
    flag=true;
    autoInt = 7;
    autoInt = autoInt + 3;
    autoChar = 'y';
    a = a + 3;
    b = b - 1;
    c = c * 2;
     a++ ;
     b-- ;
    if (flag) {
        print (string)"yes";
    }
    else {
        print (string)"no";
    }
    for (i = 0 : i<10 : i++) {
        print i;
    }
    while (a>0) {
         a-- ;
    }
    switch (c) {
        0:
            print (string)"zero";
        1, 2, 3:
            print (string)"low";
        4 to 10:
            print (string)"mid";
        default:
            print (string)"other";
    }
    for (j = 1 : j<=5 : j++) {
        print j;
    }
    print (string)raw_msg;
    print (string)raw_with_quote;
    print (string)title;
];
