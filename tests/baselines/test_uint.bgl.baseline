!% -v5
!% -E1
global _bgl_temp0;
global _bgl_temp1;

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
  with math _bglmath
;
object bgl
  with utilities _bglutil
;
object _bglMath
  with unsignedCompare [x y u v;
    if (x == y) {
        return 0;
    }
    if (x<0 && y>=0) {
        return 1;
    }
    if (x>=0 && y<0) {
        return -1;
    }
    u=x & 32767;
    v=y & 32767;
    if (u > v) {
        return 1;
    }
    return -1;
  ],
       shiftLeft [i numBits;
    return i * self.pow(2,numbits);
  ],
       shiftRight [i numBits;
    return i / self.pow(2,numbits);
  ],
       abs [p;
    if (p<0) _bgl_temp0 = -p; else _bgl_temp0 = p;
    return _bgl_temp0;
  ],
       unsignedDiv [a b lowHalf hq hr combined;
    if (b==0) {
        return 0;
    }
    if (a>=0 && b>0) {
        return a / b;
    }
    if (b<0) {
        if (self.unsignedcompare(a,b)>=0) _bgl_temp1 = 1; else _bgl_temp1 = 0;
        return _bgl_temp1;
    }
    lowHalf=a & 32767;
    hq=32767 / b;
    hr=32767 % b + 1;
    if (hr >= b) {
        hq = hq + 1;
        hr = hr - b;
    }
    combined=lowhalf + hr;
    if (combined>=0) {
        return hq + combined / b;
    }
    return hq + self.unsigneddiv(combined,b);
  ],
       unsignedMod [a b;
    if (b==0) {
        return 0;
    }
    if (a>=0 && b>0) {
        return a % b;
    }
    return a - self.unsigneddiv(a,b) * b;
  ],
       pow [i p retval t;
    if (p==0) {
        return 1;
    }
    retval=i;
    if (p<0) {
        for (t = 0 : t < (-p) - 1 : t++) {
            retval = retval / i;
        }
        return retval;
    }
    for (t = 0 : t < p - 1 : t++) {
        retval = retval * i;
    }
    return retval;
  ]
;
[_bglPrintUint v;
    if (v>=0) {
        print v;
        return;
    }
    print _bglmath.unsigneddiv(v, 10);
    print _bglmath.unsignedmod(v, 10);
];
[testInit a i b j;
    a = 42;
    i = 100;
    b=i;
    j=a;
];
[testArithmetic a b sum diff prod quot rem;
    a = 12;
    b = 10;
    sum=a + b;
    diff=a - b;
    prod=a * b;
    quot=_bglMath.unsignedDiv(a, b);
    rem=_bglMath.unsignedMod(a, b);
];
[testBitwise a b and_ or_ xor_;
    a = 12;
    b = 10;
    and_=a & b;
    or_=a | b;
    xor_=(a | b) - (a & b);
    a = a & 15;
    b = b | 4;
    a = ((a | 3) - (a & 3));
];
[testComparison x y eq neq lt lte gt gte;
    x = 5;
    y = 10;
    eq=x == y;
    neq=x ~= y;
    lt=_bglMath.unsignedCompare(x, y) < 0;
    lte=_bglMath.unsignedCompare(x, y) <= 0;
    gt=_bglMath.unsignedCompare(x, y) > 0;
    gte=_bglMath.unsignedCompare(x, y) >= 0;
];
[testCompound n;
    n = 10;
    n = n + 5;
    n = n - 2;
    n = n * 3;
    n = _bglMath.unsignedDiv(n, 4);
    n = _bglMath.unsignedMod(n, 7);
];
[testIncDec i;
    i = 0;
     i++ ;
     i-- ;
     i++ ;
     i-- ;
];
[testPrint a maxU mid;
    a = 42;
    _bglPrintUint(a);
    maxU=-1;
    _bglPrintUint(maxU);
    mid=-32768;
    _bglPrintUint(mid);
];
[testUint;
    testinit();
    testarithmetic();
    testbitwise();
    testcomparison();
    testcompound();
    testincdec();
    testprint();
];
