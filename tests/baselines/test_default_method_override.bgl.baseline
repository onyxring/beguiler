!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
class shape
  class object
  with
    describe[;
        print (string)"a shape";
    ]
;
class circle
  class shape
  with
    describe[;
        print (string)"a circle";
    ]
;
class littlecircle
  class circle
  with
    describe[;
        print (string)"a little circle";
    ]
;
global lc;
global c;
[main;
    lc.describe();
    c.describe();
];
