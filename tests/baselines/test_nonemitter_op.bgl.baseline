!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
class counter
  class object
  with
    value 0,
    _opeqeq[other;
        return self.value == other.value;
    ],
    _opadd[n;
        return self.value + n;
    ]
;
counter ctrA
  with value 5
;
counter ctrB
  with value 5
;
class temperature
  class object
  with
    celsius 0
;
class distance
  class object
  with
    meters 0
;
temperature t
  with celsius 20
;
distance d
  with meters 100
;
[main sum c doubled m;
    if (ctra._opeqeq(ctrb)) {
        print (string)"equal";
    }
    sum=ctra._opadd(10);
    c = t;
    doubled=t + t;
    m=d.meters;
];
