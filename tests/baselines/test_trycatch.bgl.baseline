!% -v5
!% -E1
global _bgl_catch_cookie;
global _bgl_cv0;
global _bgl_cvs0;
global _bgl_cv1;
global _bgl_cvs1;
global _bgl_cv2;
global _bgl_cvs2;
global _bgl_cv3;
global _bgl_cvs3;
global _bgl_cv4;
global _bgl_cvs4;
global _bgl_cv5;
global _bgl_cvs5;
global _bgl_cv6;
global _bgl_cvs6;

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[risky x;
    if (x > 10) {
        if (_bgl_catch_cookie == 0) {
            print "^[Unhandled exception]^";
            quit;
        }
        @throw x _bgl_catch_cookie;
    }
];
[doubleRisky x inner;
    _bgl_cvs0 = _bgl_catch_cookie;
    @catch -> _bgl_cv0;
    if (_bgl_catch_cookie == _bgl_cv0) {
        _bgl_catch_cookie = _bgl_cv0;
        if (x > 20) {
            if (_bgl_catch_cookie == 0) {
                print "^[Unhandled exception]^";
                quit;
            }
            @throw 99 _bgl_catch_cookie;
        }
        _bgl_catch_cookie = _bgl_cvs0;
    } else {
        _bgl_catch_cookie = _bgl_cvs0;
        inner = _bgl_cv0;
        if (_bgl_catch_cookie == 0) {
            print "^[Unhandled exception]^";
            quit;
        }
        @throw inner _bgl_catch_cookie;
    }
];
[deep;
    if (_bgl_catch_cookie == 0) {
        print "^[Unhandled exception]^";
        quit;
    }
    @throw 7 _bgl_catch_cookie;
];
[middle;
    deep();
];
class risk
  class object
  with
    n 0,
    trigger[;
        if (self.n == 0) {
            if (_bgl_catch_cookie == 0) {
                print "^[Unhandled exception]^";
                quit;
            }
            @throw 101 _bgl_catch_cookie;
        }
    ]
;
risk g_risk;
[main e a b c d e5;
    _bgl_cvs1 = _bgl_catch_cookie;
    @catch -> _bgl_cv1;
    if (_bgl_catch_cookie == _bgl_cv1) {
        _bgl_catch_cookie = _bgl_cv1;
        risky(5);
        risky(15);
        _bgl_catch_cookie = _bgl_cvs1;
    } else {
        _bgl_catch_cookie = _bgl_cvs1;
        e = _bgl_cv1;
    }
    _bgl_cvs2 = _bgl_catch_cookie;
    @catch -> _bgl_cv2;
    if (_bgl_catch_cookie == _bgl_cv2) {
        _bgl_catch_cookie = _bgl_cv2;
        _bgl_cvs3 = _bgl_catch_cookie;
        @catch -> _bgl_cv3;
        if (_bgl_catch_cookie == _bgl_cv3) {
            _bgl_catch_cookie = _bgl_cv3;
            if (_bgl_catch_cookie == 0) {
                print "^[Unhandled exception]^";
                quit;
            }
            @throw 42 _bgl_catch_cookie;
            _bgl_catch_cookie = _bgl_cvs3;
        } else {
            _bgl_catch_cookie = _bgl_cvs3;
            a = _bgl_cv3;
            if (_bgl_catch_cookie == 0) {
                print "^[Unhandled exception]^";
                quit;
            }
            @throw a _bgl_catch_cookie;
        }
        _bgl_catch_cookie = _bgl_cvs2;
    } else {
        _bgl_catch_cookie = _bgl_cvs2;
        b = _bgl_cv2;
    }
    _bgl_cvs4 = _bgl_catch_cookie;
    @catch -> _bgl_cv4;
    if (_bgl_catch_cookie == _bgl_cv4) {
        _bgl_catch_cookie = _bgl_cv4;
        middle();
        _bgl_catch_cookie = _bgl_cvs4;
    } else {
        _bgl_catch_cookie = _bgl_cvs4;
        c = _bgl_cv4;
    }
    _bgl_cvs5 = _bgl_catch_cookie;
    @catch -> _bgl_cv5;
    if (_bgl_catch_cookie == _bgl_cv5) {
        _bgl_catch_cookie = _bgl_cv5;
        risky(3);
        _bgl_catch_cookie = _bgl_cvs5;
    } else {
        _bgl_catch_cookie = _bgl_cvs5;
        d = _bgl_cv5;
    }
    _bgl_cvs6 = _bgl_catch_cookie;
    @catch -> _bgl_cv6;
    if (_bgl_catch_cookie == _bgl_cv6) {
        _bgl_catch_cookie = _bgl_cv6;
        if (g_risk ~= nothing) {
        g_risk.trigger();
        }
        _bgl_catch_cookie = _bgl_cvs6;
    } else {
        _bgl_catch_cookie = _bgl_cvs6;
        e5 = _bgl_cv6;
    }
];
