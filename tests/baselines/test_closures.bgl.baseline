!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
global _bglCap4;
global _bglCap3;
global _bglCap2;
global _bglCap1;
global _bglCap0;
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[apply fn x result;
    result=fn(x);
];
[test1 multiplier;
    _bglCap0 = multiplier;
    apply(_bglLambda_0, 5);
    multiplier = _bglCap0;
];
[test2 offset;
    offset = 10;
    _bglCap1 = offset;
    apply(_bglLambda_1, 3);
    offset = _bglCap1;
];
[test3 a b;
    _bglCap2 = a;
    _bglCap3 = b;
    apply(_bglLambda_2, 2);
    a = _bglCap2;
    b = _bglCap3;
];
[test4;
    apply(_bglLambda_3, 5);
];
[makeAdder n;
    _bglCap4 = n;
    return _bglLambda_4;
];
[test5 add5 y;
    add5 = makeadder(5);
    y=add5(10);
];
[main;
    test1(3);
    n = _bglCap4;
    test2();
    test3(4, 5);
    test4();
    test5();
];
[_bglLambda_0 x;
    return x * _bglCap0;
];
[_bglLambda_1 x;
    return x + _bglCap1;
];
[_bglLambda_2 x;
    return x * _bglCap2 + _bglCap3;
];
[_bglLambda_3 x;
    return x + 1;
];
[_bglLambda_4 x r;
    r=x + _bglCap4;
    return r;
];
