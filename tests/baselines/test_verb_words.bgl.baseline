!% -v5
!% -E1
Constant beguiler = 1000;
#Ifdef beguiler;#Endif;

    Constant story    = "";
    Constant headline = "";


    replace main _oldmain;

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
object myown
  with handler [;
    print (string)"own";
  ]
;
[myownsub;
                myown.handler();
            ];
extend 'gamma'
    * 'check' -> myown;
[main;
];
extend 'foo' first
    * noun -> myextverb;
extend 'bar'
    * noun 'down' -> myextverb;
extend 'beta'
    * noun -> myextverb2;

    [main; 
        bglInit();
        _oldmain();
    ];

