!% -v5
!% -E1
Constant _BGL_LINQ_SCRATCH_SIZE = 32;
Constant _BGL_WORLD_BUFSIZE = 128;

    Array _bglLinqScratchA table _BGL_LINQ_SCRATCH_SIZE + 2;
    Array _bglLinqScratchB table _BGL_LINQ_SCRATCH_SIZE + 2;
    Global _bglLinqParity = 0;
    [ _bglLinqWrite;
        if(_bglLinqParity == 0) return _bglLinqScratchB;
        return _bglLinqScratchA;
    ];
    [ _bglLinqFlip;
        _bglLinqParity = 1 - _bglLinqParity;
    ];


    ! `_BGL_WORLD_BUFSIZE` is declared by the compiler when `<bglWorld>` is
    ! included — value comes from #beguilerSettings.worldBufSize (default 128).
    ! Tracked-array layout: capacity word at slot 0 (auto-set by I6 from
    ! `--> N` size), data at slots 1..N, length at slot N, magic at slot N+1.
    ! +2 covers the length + magic slots.
    Array _bglWorldBuf --> _BGL_WORLD_BUFSIZE + 2;

    ! Walk all objects in the I6 object tree. `pred` is a routine address;
    ! pred==0 means no filter. The check is inside the loop so a selective
    ! predicate keeps the buffer small.
    [ _bglWorldGetAll pred o i;
        i = 0;
        objectloop(o) {
            if(i >= _BGL_WORLD_BUFSIZE) break;
            if(pred == 0 || indirect(pred, o)) {
                i++;
                _bglWorldBuf-->i = o;
            }
        }
        _bglWorldBuf-->(_bglWorldBuf-->0 - 1) = i;
        return _bglWorldBuf;
    ];

    ! Walk children of `parent`. Same pred semantics as _bglWorldGetAll.
    [ _bglWorldInParent parent pred o i;
        i = 0;
        objectloop(o in parent) {
            if(i >= _BGL_WORLD_BUFSIZE) break;
            if(pred == 0 || indirect(pred, o)) {
                i++;
                _bglWorldBuf-->i = o;
            }
        }
        _bglWorldBuf-->(_bglWorldBuf-->0 - 1) = i;
        return _bglWorldBuf;
    ];

    ! Walk objects of a class. Same pred semantics as _bglWorldGetAll.
    [ _bglWorldInstances cls pred o i;
        i = 0;
        objectloop(o ofclass cls) {
            if(i >= _BGL_WORLD_BUFSIZE) break;
            if(pred == 0 || indirect(pred, o)) {
                i++;
                _bglWorldBuf-->i = o;
            }
        }
        _bglWorldBuf-->(_bglWorldBuf-->0 - 1) = i;
        return _bglWorldBuf;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;

    _bglLinqScratchA-->(_bglLinqScratchA-->0)     = $9084;
    _bglLinqScratchA-->(_bglLinqScratchA-->0 - 1) = 0;
    _bglLinqScratchB-->(_bglLinqScratchB-->0)     = $9084;
    _bglLinqScratchB-->(_bglLinqScratchB-->0 - 1) = 0;


    _bglWorldBuf-->(_bglWorldBuf-->0)     = $9084;
    _bglWorldBuf-->(_bglWorldBuf-->0 - 1) = 0;

];
object _bglUtil
;
object bgl
  with utilities _bglutil,
       world _bglworld
;
[_bglArrayCompareAsc lhs rhs;
    
        if(lhs < rhs) return -1;
        if(lhs > rhs) return 1;
        return 0;
    
    return 0;
];
object _bglArray
  with rawGet [addr slot;
     return addr-->slot; 
    return 0;
  ],
       rawSet [addr slot v;
     addr-->slot = v; 
  ],
       get [obj prop n;
    
            if(metaclass(obj)==object) return obj.&prop-->n;
            return obj-->(n+1);
        
    return 0;
  ],
       set [obj prop n v;
    
            if(metaclass(obj)==object){ obj.&prop-->n = v; return; }
            obj-->(n+1) = v;
        
  ],
       isTracked [obj prop hdr;
     if(metaclass(obj)==object) rfalse; 
    hdr = self.rawget(obj,0);
    return self.rawget(obj,hdr)==36996&&self.rawget(obj,hdr-1)>=0;
  ],
       size [obj prop;
     if(metaclass(obj)==object) return obj.#prop/WORDSIZE; 
    if (self.istracked(obj,prop)) {
        return self.rawget(obj,0)-2;
    }
    return self.rawget(obj,0);
  ],
       length [obj prop;
     if(metaclass(obj)==object) return obj.#prop/WORDSIZE; 
    if (self.istracked(obj,prop)) {
        return self.rawget(obj,self.rawget(obj,0)-1);
    }
    return self.rawget(obj,0);
  ],
       setLength [obj prop n;
     if(metaclass(obj)==object) return; 
    if (self.istracked(obj,prop)) {
        if (n < 0) {
            print (string)"^[Beguile runtime error: setLength value exceeds signed range (max 32767 on Z, 2^31-1 on Glulx)]^";
             quit; 
        }
        self.set(obj, prop, self.size(obj,prop), n);
    }
  ],
       indexOf [obj prop val sz t;
    sz=self.size(obj,prop);
    for (t = 0 : t < sz : t++) {
        if (self.get(obj,prop,t)==val) {
            return t;
        }
    }
    return -1;
  ],
       clear [obj prop sz t;
    sz=self.size(obj,prop);
    for (t = 0 : t < sz : t++) {
        self.set(obj, prop, t, 0);
    }
    self.setLength(obj, prop, 0);
  ],
       swap [obj prop pos1 pos2 tmp;
    tmp = self.get(obj,prop,pos1);
    self.set(obj, prop, pos1, self.get(obj,prop,pos2));
    self.set(obj, prop, pos2, tmp);
  ],
       reverse [obj prop len half i;
    len=self.length(obj,prop);
    half=len / 2;
    for (i = 0 : i < half : i++) {
        self.swap(obj, prop, i, len - 1 - i);
    }
  ],
       append [obj prop val len;
    len=self.length(obj,prop);
    if (len >= self.size(obj,prop)) {
        return false;
    }
    self.set(obj, prop, len, val);
    self.setLength(obj, prop, len + 1);
    return true;
  ],
       insert [obj prop pos val len i;
    len=self.length(obj,prop);
    if (len >= self.size(obj,prop)) {
        return false;
    }
    if (pos < 0 || pos > len) {
        return false;
    }
    for (i = len : i > pos : i--) {
        self.set(obj, prop, i, self.get(obj,prop,i - 1));
    }
    self.set(obj, prop, pos, val);
    self.setLength(obj, prop, len + 1);
    return true;
  ],
       prepend [obj prop val;
    return self.insert(obj,prop,0,val);
  ],
       remove [obj prop pos len i;
    len=self.length(obj,prop);
    if (pos < 0 || pos >= len) {
        return;
    }
    for (i = pos : i < len - 1 : i++) {
        self.set(obj, prop, i, self.get(obj,prop,i + 1));
    }
    self.set(obj, prop, len - 1, 0);
    self.setLength(obj, prop, len - 1);
  ],
       removeValue [obj prop val pos len;
    pos = 0;
    len=self.length(obj,prop);
    while (pos < len) {
        if (self.get(obj,prop,pos)==val) {
            self.remove(obj, prop, pos);
            len = self.length(obj,prop);
        }
        else {
             pos++ ;
        }
    }
  ],
       push [obj prop val;
    self.insert(obj, prop, 0, val);
  ],
       pop [obj prop v;
    if (self.length(obj,prop) == 0) {
        return 0;
    }
    v = self.get(obj,prop,0);
    self.remove(obj, prop, 0);
    return v;
  ],
       dequeue [obj prop;
    return self.pop(obj,prop);
  ],
       enqueue [obj prop val;
    self.append(obj, prop, val);
  ],
       peek [obj prop;
    if (self.length(obj,prop) == 0) {
        return 0;
    }
    return self.get(obj,prop,0);
  ],
       peekEnd [obj prop len;
    len=self.length(obj,prop);
    if (len == 0) {
        return 0;
    }
    return self.get(obj,prop,len - 1);
  ],
       popEnd [obj prop len v;
    len=self.length(obj,prop);
    if (len == 0) {
        return 0;
    }
    v = self.get(obj,prop,len - 1);
    self.remove(obj, prop, len - 1);
    return v;
  ],
       sort [obj prop compare len i key j;
    len=self.length(obj,prop);
    for (i = 1 : i < len : i++) {
        key = self.get(obj,prop,i);
        j=i - 1;
        while (j >= 0 && compare(self.get(obj,prop,j),key) > 0) {
            self.set(obj, prop, j + 1, self.get(obj,prop,j));
             j-- ;
        }
        self.set(obj, prop, j + 1, key);
    }
  ],
       filter [obj prop pred dst cap writeCount srcLen i elem;
    dst = _bgllinqwrite();
    cap = 32;
    writeCount = 0;
    srcLen=self.length(obj,prop);
    for (i = 0 : i < srclen : i++) {
        elem = self.get(obj,prop,i);
        if (pred(elem)) {
            if (writecount >= cap) {
                
                        print "^[Beguile runtime error: filter() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                        quit;
                    
            }
            dst-->(writecount+1) = elem;
             writecount++ ;
        }
    }
    _bglArray.setLength(dst, 0, writeCount);
    _bgllinqflip();
    return dst;
  ],
       first [obj prop;
    if (self.length(obj,prop) == 0) {
        return 0;
    }
    return self.get(obj,prop,0);
  ],
       last [obj prop len;
    len=self.length(obj,prop);
    if (len == 0) {
        return 0;
    }
    return self.get(obj,prop,len - 1);
  ],
       any [obj prop pred len i;
    len=self.length(obj,prop);
    for (i = 0 : i < len : i++) {
        if (pred(self.get(obj,prop,i))) {
            return true;
        }
    }
    return false;
  ],
       all [obj prop pred len i;
    len=self.length(obj,prop);
    for (i = 0 : i < len : i++) {
        if (~~pred(self.get(obj,prop,i))) {
            return false;
        }
    }
    return true;
  ],
       map [obj prop f dst cap srcLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    if (srclen > cap) {
        
                print "^[Beguile runtime error: map() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < srclen : i++) {
        dst-->(i+1) = f(self.get(obj,prop,i));
    }
    _bglArray.setLength(dst, 0, srcLen);
    _bgllinqflip();
    return dst;
  ],
       take [obj prop n dst cap srcLen outLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    outLen=n;
    if (outlen < 0) {
        outLen = 0;
    }
    if (outlen > srclen) {
        outLen = srcLen;
    }
    if (outlen > cap) {
        
                print "^[Beguile runtime error: take() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < outlen : i++) {
        dst-->(i+1) = self.get(obj,prop,i);
    }
    _bglArray.setLength(dst, 0, outLen);
    _bgllinqflip();
    return dst;
  ],
       skip [obj prop n dst cap srcLen start outLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    start=n;
    if (start < 0) {
        start = 0;
    }
    if (start > srclen) {
        start = srcLen;
    }
    outLen=srclen - start;
    if (outlen > cap) {
        
                print "^[Beguile runtime error: skip() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < outlen : i++) {
        dst-->(i+1) = self.get(obj,prop,start + i);
    }
    _bglArray.setLength(dst, 0, outLen);
    _bgllinqflip();
    return dst;
  ],
       takeWhile [obj prop pred dst cap srcLen outLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    outLen = 0;
    for (i = 0 : i < srclen : i++) {
        if (~~pred(self.get(obj,prop,i))) {
            break;
        }
        if (outlen >= cap) {
            
                    print "^[Beguile runtime error: takeWhile() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                    quit;
                
        }
        dst-->(outlen+1) = self.get(obj,prop,i);
         outlen++ ;
    }
    _bglArray.setLength(dst, 0, outLen);
    _bgllinqflip();
    return dst;
  ],
       skipWhile [obj prop pred dst cap srcLen start outLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    start = 0;
    while (start < srclen && pred(self.get(obj,prop,start))) {
         start++ ;
    }
    outLen=srclen - start;
    if (outlen > cap) {
        
                print "^[Beguile runtime error: skipWhile() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < outlen : i++) {
        dst-->(i+1) = self.get(obj,prop,start + i);
    }
    _bglArray.setLength(dst, 0, outLen);
    _bgllinqflip();
    return dst;
  ],
       distinct [obj prop dst cap srcLen outLen i elem seen j;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    outLen = 0;
    for (i = 0 : i < srclen : i++) {
        elem = self.get(obj,prop,i);
        seen=false;
        for (j = 0 : j < outlen : j++) {
            if ( dst-->(j+1) ==elem) {
                seen = true;
                break;
            }
        }
        if (~~seen) {
            if (outlen >= cap) {
                
                        print "^[Beguile runtime error: distinct() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                        quit;
                    
            }
            dst-->(outlen+1) = elem;
             outlen++ ;
        }
    }
    _bglArray.setLength(dst, 0, outLen);
    _bgllinqflip();
    return dst;
  ],
       orderBy [obj prop compare dst cap srcLen i;
    dst = _bgllinqwrite();
    cap = 32;
    srcLen=self.length(obj,prop);
    if (srclen > cap) {
        
                print "^[Beguile runtime error: orderBy() output exceeds linqScratchSize. Increase via #beguilerSettings.linqScratchSize.]^";
                quit;
            
    }
    for (i = 0 : i < srclen : i++) {
        dst-->(i+1) = self.get(obj,prop,i);
    }
    _bglArray.setLength(dst, 0, srcLen);
    self.sort(dst, 0, compare);
    _bgllinqflip();
    return dst;
  ]
;
object _bglWorld
  with getAll [pred;
    return _bglworldgetall(pred);
  ],
       inParent [p pred;
    return _bglworldinparent(p,pred);
  ],
       instances [cls pred;
    return _bglworldinstances(cls,pred);
  ]
;
class animal
  class object
  with
    legs 4
;
object cage
  with short_name "cage"
;
animal dog cage
  with short_name "dog"
;
animal cat cage
  with short_name "cat"
;
animal fish
  with short_name "fish"
;
object stone cage
  with short_name "stone"
;
[main totalCount caged animals o _bglfia0 _bglfi1 cagedAnimals cageWithoutStones notFish;
    totalCount=_bglArray.length(_bglworld.getall(0), 0);
    print (string)"total objects: ";
    print totalCount;
    print (string)"^";
    caged=_bglArray.length(_bglworld.inparent(cage, 0), 0);
    print (string)"in cage: ";
    print caged;
    print (string)"^";
    animals=_bglArray.length(_bglworld.instances(animal, 0), 0);
    print (string)"animals: ";
    print animals;
    print (string)"^";
    print (string)"named animals:^";
    _bglfia0 = _bglworld.instances(animal, 0);
    _bglfi1 = 0;
    for (: _bglfi1 < _bglArray.length(_bglfia0, 0) : _bglfi1++) {
        o = _bglfia0-->(_bglfi1+1);
        print (string)" - ";
        print o.short_name;
        print (string)"^";
    }
    cagedAnimals=_bglArray.length(_bglworld.instances(animal, _bglLambda_0), 0);
    print (string)"caged animals (in-walk filter): ";
    print cagedAnimals;
    print (string)"^";
    cageWithoutStones=_bglArray.length(_bglworld.inparent(cage, _bglLambda_1), 0);
    print (string)"cage without stones: ";
    print cageWithoutStones;
    print (string)"^";
    notFish=_bglArray.length(_bglworld.getall(_bglLambda_2), 0);
    print (string)"everything except fish: ";
    print notFish;
    print (string)"^";
];
[_bglLambda_0 o;
    return o.parent == cage;
];
[_bglLambda_1 o;
    return o ~= stone;
];
[_bglLambda_2 o;
    return o ~= fish;
];
