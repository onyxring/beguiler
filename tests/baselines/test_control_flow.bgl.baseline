!% -G
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[testIf n;
    if (n < 0) {
        print (string)"negative";
    }
    else {
        if (n == 0) {
            print (string)"zero";
        }
        else {
            print (string)"positive";
        }
    }
];
[testNestedIf a b;
    if (a > 0) {
        if (b > 0) {
            print (string)"both positive";
        }
        else {
            print (string)"a positive, b not";
        }
    }
    else {
        print (string)"a not positive";
    }
];
[countdown start n;
    n=start;
    while (n > 0) {
        n = n - 1;
    }
    return n;
];
[findFirst target i;
    i = 0;
    while (i < 100) {
        if (i == target) {
            break;
        }
        i = i + 1;
    }
    return i;
];
[countOdd max i count;
    i = 0;
    count = 0;
    while (i < max) {
        i = i + 1;
        if ((i / 2) * 2 == i) {
            continue;
        }
        count = count + 1;
    }
    return count;
];
[firstPositive a b c;
    if (a > 0) {
        return a;
    }
    if (b > 0) {
        return b;
    }
    if (c > 0) {
        return c;
    }
    return 0;
];
[testControlFlow cd ff odds fp;
    testif(-1);
    testif(0);
    testif(5);
    testnestedif(1, 2);
    testnestedif(1, -1);
    testnestedif(-1, 1);
    cd=countdown(5);
    ff=findfirst(7);
    odds=countodd(10);
    fp=firstpositive(-1,-2,3);
];
