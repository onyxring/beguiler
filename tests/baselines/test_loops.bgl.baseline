!% -v5
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglArray
  with isTracked [arr;
    return  arr-->( arr-->(-1+1) -1+1) ==36996&& arr-->( arr-->(-1+1) -2+1) >=0;
  ],
       size [arr;
    if (self.istracked(arr)) {
        return  arr-->(-1+1) -2;
    }
    return  arr-->(-1+1) ;
  ],
       length [arr;
    if (self.istracked(arr)) {
        return  arr-->( arr-->(-1+1) -2+1) ;
    }
    return  arr-->(-1+1) ;
  ],
       setLength [arr n;
    if (self.istracked(arr)) {
        if (n<0) {
            print (string)"^[Beguile runtime error: setLength value exceeds signed range (max 32767 on Z, 2^31-1 on Glulx)]^";
             quit; 
        }
        arr-->(_bglArray.size(arr)+1) = n;
    }
  ]
;
object _bglUtil
;
object bgl
  with utilities _bglutil
;
[forUntyped i;
    for (i = 0 : i<5 : i++) {
        print i;
    }
];
[forTyped i;
    for (i = 0 : i<5 : i++) {
        print i;
    }
];
[forTypedReuse i;
    for (i = 0 : i<3 : i++) {
        print i;
    }
    for (i = 0 : i<3 : i++) {
        print i;
    }
];
[nestedLoops row col cell;
    for (row = 0 : row<3 : row++) {
        for (col = 0 : col<3 : col++) {
            cell = row * 3 + col;
            print cell;
        }
    }
];
[whileBreakContinue i;
    i = 0;
    while (i<10) {
         i++ ;
        if (i==3) {
            continue;
        }
        if (i==7) {
            break;
        }
        print i;
    }
];
[doWhileLoop n;
    n = 0;
    do {
        print n;
         n++ ;
    } until (~~(n<3));
];
[doUntilLoop n;
    n = 0;
    do {
        print n;
         n++ ;
    } until (n>=3);
];
[main;
    foruntyped();
    fortyped();
    fortypedreuse();
    nestedloops();
    whilebreakcontinue();
    dowhileloop();
    dountilloop();
];
