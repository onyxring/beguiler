!% -v5
!% -E1
global _bgl_temp0;

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
class score
  class object
  with
    value 0,
    get[;
        return self.value;
    ]
;
score g_pts
  with value 42
;
[main pts bonus;
    pts = 42;
    bonus = 8;
    print "Score: ";
    print pts;
    print "^";
    print "Use {braces} for interpolation.^";
     ;
    print "Total: ";
    print pts + bonus;
    print "^";
    print "Product: ";
    print pts * 2;
    print "^";
    print "Final: ";
    print g_pts.get();
    print "^";
    print "Grade: ";
    if (pts > 50) _bgl_temp0 = 1; else _bgl_temp0 = 0;
    print _bgl_temp0;
    print "^";
    print pts;
    print " plus ";
    print bonus;
    print " is ";
    print pts + bonus;
    print "^";
];
