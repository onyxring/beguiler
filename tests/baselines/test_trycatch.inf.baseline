!% -v5
!% -E1
global _bgl_catch_cookie;
global _bgl_cv0;
global _bgl_cvs0;
global _bgl_cv1;
global _bgl_cvs1;
global _bgl_cv2;
global _bgl_cvs2;
global _bgl_cv3;
global _bgl_cvs3;
global _bgl_cv4;
global _bgl_cvs4;
global _bgl_cv5;
global _bgl_cvs5;
[bglInit;
];

Array _bglWorldBuf --> 257;   ! capacity word (-->0) + 256 object slots

object bglWorld
    with getAll [ o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o) {
            if (i > 256) break;
            _bglWorldBuf-->i = o;
            i++;
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    getFiltered [ pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o) {
            if (i > 256) break;
            if (indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    inParent [ parent pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o in parent) {
            if (i > 256) break;
            if (pred == 0 || indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ],
    ofClass [ cls pred o i;
        _bglWorldBuf-->0 = 256;
        i = 1;
        objectloop(o ofclass cls) {
            if (i > 256) break;
            if (pred == 0 || indirect(pred, o)) { _bglWorldBuf-->i = o; i++; }
        }
        _bglWorldBuf-->i = 0;
        return _bglWorldBuf;
    ]
;

[risky x;
    if (x > 10) {
        if (_bgl_catch_cookie == 0) {
            print "^[Unhandled exception]^";
            quit;
        }
        @throw x _bgl_catch_cookie;
    }
];
[doublerisky x inner;
    @catch -> _bgl_cv0 ?_bgl_try0;
        inner = _bgl_cv0;
        if (_bgl_catch_cookie == 0) {
            print "^[Unhandled exception]^";
            quit;
        }
        @throw inner _bgl_catch_cookie;
        jump _bgl_tryend0;
    ._bgl_try0;
        _bgl_cvs0 = _bgl_catch_cookie;
        _bgl_catch_cookie = _bgl_cv0;
        if (x > 20) {
            if (_bgl_catch_cookie == 0) {
                print "^[Unhandled exception]^";
                quit;
            }
            @throw 99 _bgl_catch_cookie;
        }
        _bgl_catch_cookie = _bgl_cvs0;
    ._bgl_tryend0;
];
[deep;
    if (_bgl_catch_cookie == 0) {
        print "^[Unhandled exception]^";
        quit;
    }
    @throw 7 _bgl_catch_cookie;
];
[middle;
    deep();
];
[main e a b c d;
    @catch -> _bgl_cv1 ?_bgl_try1;
        e = _bgl_cv1;
        jump _bgl_tryend1;
    ._bgl_try1;
        _bgl_cvs1 = _bgl_catch_cookie;
        _bgl_catch_cookie = _bgl_cv1;
        risky(5);
        risky(15);
        _bgl_catch_cookie = _bgl_cvs1;
    ._bgl_tryend1;
    @catch -> _bgl_cv2 ?_bgl_try2;
        b = _bgl_cv2;
        jump _bgl_tryend2;
    ._bgl_try2;
        _bgl_cvs2 = _bgl_catch_cookie;
        _bgl_catch_cookie = _bgl_cv2;
        @catch -> _bgl_cv3 ?_bgl_try3;
            a = _bgl_cv3;
            if (_bgl_catch_cookie == 0) {
                print "^[Unhandled exception]^";
                quit;
            }
            @throw a _bgl_catch_cookie;
            jump _bgl_tryend3;
        ._bgl_try3;
            _bgl_cvs3 = _bgl_catch_cookie;
            _bgl_catch_cookie = _bgl_cv3;
            if (_bgl_catch_cookie == 0) {
                print "^[Unhandled exception]^";
                quit;
            }
            @throw 42 _bgl_catch_cookie;
            _bgl_catch_cookie = _bgl_cvs3;
        ._bgl_tryend3;
        _bgl_catch_cookie = _bgl_cvs2;
    ._bgl_tryend2;
    @catch -> _bgl_cv4 ?_bgl_try4;
        c = _bgl_cv4;
        jump _bgl_tryend4;
    ._bgl_try4;
        _bgl_cvs4 = _bgl_catch_cookie;
        _bgl_catch_cookie = _bgl_cv4;
        middle();
        _bgl_catch_cookie = _bgl_cvs4;
    ._bgl_tryend4;
    @catch -> _bgl_cv5 ?_bgl_try5;
        d = _bgl_cv5;
        jump _bgl_tryend5;
    ._bgl_try5;
        _bgl_cvs5 = _bgl_catch_cookie;
        _bgl_catch_cookie = _bgl_cv5;
        risky(3);
        _bgl_catch_cookie = _bgl_cvs5;
    ._bgl_tryend5;
];
