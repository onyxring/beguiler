!% -v5
!% -E1

    Array _bglScratchStack --> 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
global g_isActive = true;
global g_isInactive;
global g_score = 0;
global g_moves;
global g_scratch;
constant MAX_ROOMS = 20;
constant MAX_ITEMS = 10;
constant TITLE = "test";
array g_roomexits table 6;
array g_itemids table 10;
array g_primes table 2 3 5 7 11;
array g_fibonacci table 1 1 2 3 5 8;
[main first total;
    g_score = 0;
    g_moves = 0;
    g_scratch = 42;
    first =  g_primes-->(0+1) ;
    total =  g_primes-->(0+1) ;
];
