!% -v5
!% -E1

    Array _bglScratchStack table 33;
    Global _bglScratchTop = 0;
    [ _bglScratchPush v;
        if(_bglScratchTop >= 31){
            print "^[Beguile runtime error: for-in literal-list scratch exhausted]^";
            quit;
        }
        _bglScratchTop++;
        _bglScratchStack-->_bglScratchTop = v;
    ];
    [ _bglScratchMake count;
        _bglScratchStack-->(_bglScratchStack-->0) = $9084;     ! magic marker
        _bglScratchStack-->(_bglScratchStack-->0 - 1) = count; ! length
        _bglScratchTop = 0;
        return _bglScratchStack;
    ];

global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglUtil
;
object bgl
  with utilities _bglutil
;
class room
  class object
  with
    visits 0
;
room r1;
room r2;
room r3;
[main total x _bglfia0 _bglfi1 m n y _bglfia2 _bglfi3 seen r _bglfia4 _bglfi5;
    total = 0;
    _bglScratchPush(1);
    _bglScratchPush(2);
    _bglScratchPush(3);
    _bglfia0 = _bglScratchMake(3);
    _bglfi1 = 0;
    for (: _bglfi1 < _bglfia0-->0 : _bglfi1++) {
        x = _bglfia0-->(_bglfi1+1);
        total = total + x;
    }
    print total;
    m = 4;
    n = 5;
    _bglScratchPush(m);
    _bglScratchPush(n);
    _bglScratchPush(m * n);
    _bglfia2 = _bglScratchMake(3);
    _bglfi3 = 0;
    for (: _bglfi3 < _bglfia2-->0 : _bglfi3++) {
        y = _bglfia2-->(_bglfi3+1);
        total = total + y;
    }
    print total;
    seen = 0;
    _bglScratchPush(r1);
    _bglScratchPush(r2);
    _bglScratchPush(r3);
    _bglfia4 = _bglScratchMake(3);
    _bglfi5 = 0;
    for (: _bglfi5 < _bglfia4-->0 : _bglfi5++) {
        r = _bglfia4-->(_bglfi5+1);
        seen = seen + 1;
    }
    print seen;
];
