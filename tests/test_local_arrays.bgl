/*
    test_local_arrays.bgl

    Local Beguile-declared word arrays via framePool. Each function call gets
    its own slice (alloc on entry, free on every return path). Recursion is
    supported because the framePool is stack-disciplined.

    Coverage:
      • Basic local sized-uninit array: alloc/use/free cycle.
      • Multiple local arrays in one function — all alloc'd and all freed.
      • Recursive call with a local array — each frame gets its own backing.
      • Function returning early from a deep position — cleanup still fires.
*/
#beguilerSettings {
    target = z5;
    informName = "none";
    outputPath = "tests/output";
}
#include <array>

// Recursive sum-up-to-N using a local accumulator array. Each call gets its
// own array (proves the framePool stack discipline).
int sumDown(int n){
    array<int> acc[4];
    if(n <= 0) return 0;
    acc.append(n);
    // Recurse — inner call gets its own `acc`.
    int rest = sumDown(n - 1);
    return acc[0] + rest;
}

// Multiple locals in one function — all should alloc/free correctly.
int useTwoLocals(int a, int b){
    array<int> first[3];
    array<int> second[3];
    first.append(a);
    first.append(b);
    second.append(a + b);
    return first[0] + first[1] + second[0];
}

// Early return — cleanup must still fire on the return path.
int earlyReturn(bool flag){
    array<int> buf[5];
    buf.append(100);
    if(flag) return buf[0];   // cleanup runs here
    buf.append(200);
    return buf[1];             // cleanup runs here too
}

// Sum a local array's length-tracked elements. Receives a tracked array by
// reference; length() must survive the call (regression: list-init locals used
// to emit no allocation, so the pointer was garbage on entry).
int sumAll(array<int> data){
    int total = 0;
    for(int i = 0; i < data.length(); i++) total = total + data[i];
    return total;
}

// List-initialized local array: `array<int> name = {…}` inside a function body.
// Allocation is hoisted to function entry; element values + tracked length are
// written at the declaration point. Used directly and passed to a helper.
int listInitLocal(){
    array<int> primes = {2, 3, 5, 7, 11};   // length starts at 5
    return primes.length() * 100 + sumAll(primes);  // 5*100 + 28 = 528
}

// Sized local BYTE array (array<char>) via framePool hybrid-buffer backing:
// capacity word at -->0, data bytes at ->WORDSIZE. Filled by subscript, read back.
int localByteArray(){
    array<char> buf[8];
    buf[0] = 'X';
    buf[1] = 'Y';
    char c0 = buf[0];
    char c1 = buf[1];
    if(c0 == 'X' && c1 == 'Y') return 777;   // write/read round-trips
    return 0;
}

void main(){
    print(sumDown(5));         // 5+4+3+2+1 = 15

    print(useTwoLocals(3, 4)); // first[0]+first[1]+second[0] = 3+4+7 = 14

    print(earlyReturn(true));  // 100
    print(earlyReturn(false)); // 200

    print(listInitLocal());    // 528

    print(localByteArray());   // 'X' + 'Y' = 177
}
