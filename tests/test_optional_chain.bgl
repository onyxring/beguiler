/* test_optional_chain.bgl — optional chaining, null coalescing, postfix query */
#beguilerSettings {
    target = z5;
    informName = "none";
    outputPath = "tests/output";
}

attribute light;

void main(){
    // Optional chaining in expression — method call through ?.
    object x = null;
    bool lit = x?.has(light);

    // Postfix query
    if(x?) print("present");
    if(!x?) print("absent");

    // Statement-level optional chaining
    x?.remove();
}
