!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglutil
;
object bgl
  with util _bglutil
;
[double n;
    return n * 2;
];
[main sum i total a b count x y;
    sum = 0;
    for (i = 0 : i * 2<10 : i ++) {
        sum = sum + i;
    }
    print sum;
    total = 0;
    for (i = 0 : i<5 : i += 1 + 0) {
        total = total + 1;
    }
    print total;
    a = 5;
    b = 3;
    count = 0;
    while (a>0 && b>0||count==0) {
         count++ ;
         a-- ;
         b-- ;
        if (count>10) {
            break;
        }
    }
    print count;
    x = 0;
    for (i = 0 : double(i) + 1<10 : i ++) {
        x = i;
    }
    print x;
    y = 0;
    for (i = 0 : i<10 && i * i<50 : i ++) {
        y = i;
    }
    print y;
];
