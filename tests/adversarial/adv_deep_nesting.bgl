/* Adversarial: deeply nested control flow — stress the block-local hoister
   and the statement parser's recursion depth. */
#beguilerSettings { target = z5; informName = "none"; outputPath = "tests/output"; }
void main() {
    int a = 1;
    if(a > 0){
        int b = 2;
        for(int i = 0; i < 3; i++){
            int c = 3;
            while(c > 0){
                int d = 4;
                if(d > 0){
                    int e = a + b + c + d;
                    print(e);
                    c = 0;
                }
            }
        }
    }
}
