!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglutil
;
object bgl
  with util _bglutil
;
class base
  class object
  with
    shared 0
;
class left
