  with
    rightval 2
;
class diamond
  class left right
  with
    test[s l r;
        s=self.shared;
        l=self.leftval;
        r=self.rightval;
    ]
;
class foo
  class object
  with
    x 1
;
class bar
  class object
  with
    y 2
;
global f;
global b;
[main d;
