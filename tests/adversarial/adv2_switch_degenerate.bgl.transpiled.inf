!% -v5
!% -E1
global _bgl_sw;
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglutil
;
object bgl
  with util _bglutil
;
[main val cmd;
    val = 5;
    switch (val) {
        default:
            print (string)"only default";
    }
    _bgl_sw = val;
    if ((_bgl_sw >= 1 && _bgl_sw <= 3)) {
        print (string)"low range";
    }
    else if ((_bgl_sw > 10)) {
        print (string)"high guard";
    }
    else if (_bgl_sw == 4 || _bgl_sw == 5) {
        print (string)"four or five";
    }
    else {
        print (string)"other";
    }
    cmd="quit";
    switch (cmd) {
        "look":
            print (string)"looking";
        "quit", "exit":
            print (string)"leaving";
        default:
            print (string)"huh?";
    }
];
