!% -v5
!% -E1
global _bglInitDone = 0;
[bglInit;
    if(_bglInitDone) return;
    _bglInitDone = 1;
];
object _bglutil
;
object bgl
  with util _bglutil
;
[main a b chain flag r t;
    a = 5;
    b = 10;
    chain=a < b && b<20;
    if (a & 1) {
        print a;
    }
    flag = 1;
    flag=(flag | 1) - (flag & 1);
    flag=(flag | 1) - (flag & 1);
    r=5 + 3;
    t=5 < 10;
    print r;
];
