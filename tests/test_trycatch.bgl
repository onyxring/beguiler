/* test_trycatch.bgl — try/catch/throw exception handling */
#beguilerSettings {
    target = z5;
    informName = "none";
    outputPath = "tests/output";
}

// --- Test 1: basic throw and catch ---
void risky(int x){
    if(x > 10) throw x;
}

// --- Test 2: nested try/catch ---
void doubleRisky(int x){
    try {
        if(x > 20) throw 99;
    } catch(int inner) {
        throw inner;
    }
}

// --- Test 3: throw across call frames ---
void deep(){
    throw 7;
}
void middle(){
    deep();
}

// --- Test 5: throw reached through optional chain ---
// A method called via `?.` that throws — the throw should unwind past the optional-chain
// frame and be caught by the enclosing try.
class Risk : object {
    int n = 0;
    void trigger() { if(n == 0) throw 101; }
}
Risk g_risk;

void main(){
    // Test 1: basic catch
    try {
        risky(5);
        risky(15);
    } catch(int e) {
    }

    // Test 2: nested
    try {
        try {
            throw 42;
        } catch(int a) {
            throw a;
        }
    } catch(int b) {
    }

    // Test 3: cross-frame throw
    try {
        middle();
    } catch(int c) {
    }

    // Test 4: no throw — normal completion
    try {
        risky(3);
    } catch(int d) {
    }

    // Test 5: throw via optional chain — g_risk?.trigger() throws when n == 0;
    // the exception unwinds past the optional chain and is caught here.
    try {
        g_risk?.trigger();
    } catch(int e5) {
    }
}
