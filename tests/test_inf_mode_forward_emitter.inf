!% -v5
!% -E1

! test_inf_mode_forward_emitter.inf — emitter functions declared inside a `#bgl{}`
! island must be reachable as forward calls from earlier members. This requires
! three pieces working together:
!   (1) preScanBglIslandContent keeps functionDef stubs for the second pass
!       (otherwise the stub is erased and forward-call lookup fails).
!   (2) The emitter qualifier is propagated to the stub's `isEmitter` field.
!   (3) The emitter's I6 body is captured during prescan so the call site can
!       inline it (without a body, dispatch falls back to verbatim emission).

#bgl{
    #include <bindings/i6StandardLibrary>

    object myObj;

    // Use of `the(myObj)` precedes its declaration. The auto-detector treats this
    // whole island as declarations because the first content token is a directive.
    void caller() {
        the(myObj);
    }

    emitter void the(object o){
        (the)$o
    }
}
end;
