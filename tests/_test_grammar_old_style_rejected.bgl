// _test_grammar_old_style_rejected.bgl
// `grammar VerbName { ... }` bodies hold grammarRule members; bare grammar lines
// belong inside `extend VerbName { grammar += { ... }; }`. The parser must direct
// authors to the right form.
// EXPECT_ERROR: bodies hold grammarRule members, not bare grammar lines

#beguilerSettings {
    target = z5;
    informName = "none";
    outputPath = "tests/output";
}

#include <bindings/i6StandardLibrary>

grammar PutOn {
    {.hang, HELD, .on, noun},
}
