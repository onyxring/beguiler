// test_meta_verbs.bgl — meta verb declarations.
// `meta` is a property on `class verb`. Authors set it like any other property:
// `meta = true;` inside the verb body. The compiler suppresses it from the I6
// `with` clause and lifts it onto the Verb directive (`Verb meta '...' -> Action;`).
//
// Uses fresh dict words (.census, .tally, .ponder) that don't collide with the
// stdlib's existing extern verbs — otherwise the new trigger word would be treated
// as an Extend on an already-declared verb (no meta directive emitted there).
#beguilerSettings {
    target = z5;
    informName = "none";
    outputPath = "tests/output";
}

#include <bindings/i6StandardLibrary>

// Beguile-defined meta verb — `meta = true;` lifts to `Verb meta` directive
verb Census {
    meta = true;
    grammar = {
        {.census},
        {.tally},
    };
    void perform(){ print("census"); }
}

// Non-meta verb — emits as plain `Verb`
verb Ponder {
    grammar = {
        {.ponder, noun},
    };
    void perform(){ print("ponder"); }
}

void main(){}
