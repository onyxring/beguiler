/* test_basics.bgl — basic types, operators, assignments, control flow */
#beguilerSettings {
    target = z5;
    informName = "none";
    outputPath = "tests/output";
    release = 1;
}

#define DEBUG
#define GAME_MODE 2

const int MAX = 100;
const string TITLE = "Test";

// Raw string literal (spec §2.5.2a) — @"..." disables escape processing except
// for \" (escaped double-quote). Embedded backslashes, quotes, and characters
// pass through to the emitted I6 string as-is.
const string RAW_MSG = @"raw \n stays literal and \t too";
const string RAW_WITH_QUOTE = @"has a ""quoted"" word";

void main(){
    // Variable declarations and assignments
    int a = 5;
    int b = 10;
    int c = a + b;
    string s = "hello";
    char ch = 'x';
    bool flag = true;

    // `auto` type inference via operator auto() on literal pseudo-types.
    // intLiteral.operator auto() returns int → autoInt resolves to int, not intLiteral,
    // giving it full int operator support. Spec §7.9a.
    auto autoInt = 7;
    autoInt += 3;
    auto autoChar = 'y';

    // Compound assignment
    a += 3;
    b -= 1;
    c *= 2;

    // Increment/decrement
    a++;
    b--;

    // Control flow
    if(flag){
        print("yes");
    } else {
        print("no");
    }

    // For loop
    for(int i = 0; i < 10; i++){
        print(i);
    }

    // While loop
    while(a > 0){
        a--;
    }

    // Switch with values and ranges
    switch(c){
        case 0: print("zero");
        case 1, 2, 3: print("low");
        case 4 to 10: print("mid");
        default: print("other");
    }

    // Ternary (uses ? which conflicts with postfix query — known issue)
    // int result = flag ? a : b;

    // Range for-in
    for(int j in 1 to 5){
        print(j);
    }

    // Raw string literals — reference them so they're not dead-stripped
    print(RAW_MSG);
    print(RAW_WITH_QUOTE);

    // Return
    print(TITLE);
}
