! test_inf_mode_emitfirst_additive.inf — Slice 5c: #emitfirst is additive across all
! references in the same source file. Multiple #bglDecl islands each contributing an
! #emitfirst block must all register; the previous per-file dedup gate is gone (#once
! is now the sole mechanism for re-include cycle protection).

#bglDecl{
    #emitfirst{
        Constant FROM_FIRST_ISLAND;
    }
}

#bglDecl{
    #emitfirst{
        Constant FROM_SECOND_ISLAND;
    }
}

#bglDecl{
    #emitfirst{
        Constant FROM_THIRD_ISLAND;
    }
}

[ Main;
    print "hi.^";
];

end;
