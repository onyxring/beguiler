		,	endsWith[buf2 caseInsensitive; return _orBuf.endsWith(self.getBuf(), _orStr.toAmbiguousBuffer(buf2),  caseInsensitive);]
		,	endsWithOneOf[buf1 buf2 buf3 buf4 caseInsensitive;
				if(buf4==true or false) caseInsensitive=buf4;
