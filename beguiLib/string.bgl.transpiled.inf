				if(self.equals(buf1, caseInsensitive)==true) rtrue;
				if((~~(buf2==true or false)) && self.equals(buf2, caseInsensitive)==true) rtrue;
				if((~~(buf3==true or false)) && self.equals(buf3, caseInsensitive)==true) rtrue;
