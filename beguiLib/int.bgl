#include<math>

extend class int {
    emitter int operator << (int v){ 
        bgl.utilities.math.shiftLeft($self,$v)            
    }
    emitter int operator <<= (int v){ 
        $self=bgl.utilities.math.shiftLeft($self,$v)            
    }
    emitter int operator >> (int v){ 
        bgl.utilities.math.shiftRight($self,$v)            
    }
    emitter int operator >>= (int v){ 
        $self=bgl.utilities.math.shiftRight($self,$v)            
    }
}